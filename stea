	local g=Instance.new("UIGradient",obj); g.Color=colors
	task.spawn(function()
		local o=0; while obj and obj.Parent do o=(o+speed)%1; g.Offset=Vector2.new(o,0); task.wait(0.03) end
	end)
	return g
end

