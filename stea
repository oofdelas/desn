local function applyRow(rd, entry, idx)
	rd.entryUID  = entry.uid   -- FIX bug 2
	rd.entryName = entry.name
	rd.rankLbl.Text="#"..idx
	rd.nameLbl.Text=entry.name
	rd.incomeLbl.Text="$"..formatMoney(entry.income).."/s"

	local mc=getMutColor(entry.mutation)
	local ml=getMutLabel(entry.mutation)
	if ml and mc then
		rd.mutLbl.Text="✦ "..ml
		rd.mutLbl.TextColor3=mc
		rd.mutBadge.BackgroundColor3=Color3.new(mc.R*0.18,mc.G*0.18,mc.B*0.18)
		rd.mutBadge.BackgroundTransparency=0.08
		local mstr=rd.mutBadge:FindFirstChildOfClass("UIStroke")
		if not mstr then
			mstr=Instance.new("UIStroke",rd.mutBadge)
			mstr.ApplyStrokeMode=Enum.ApplyStrokeMode.Border; mstr.Thickness=1.3; mstr.Transparency=0.05
		end
		mstr.Color=mc; rd.mutBadge.Visible=true
	else
		rd.mutBadge.Visible=false; rd.mutLbl.Text=""
	end

	rd.prioTag.Visible=entry.isPriority

	-- FIX bug 2: compara UID
	local isSel=(State.selectedUID==entry.uid)
	rd.selTag.Visible=isSel

	if isSel then
		rd.rankBadge.BackgroundColor3=Color3.fromRGB(60,220,130)
		rd.stroke.Color=Color3.fromRGB(80,255,150); rd.stroke.Transparency=0; rd.stroke.Thickness=2
		rd.row.BackgroundColor3=Color3.fromRGB(20,40,30); rd.nameLbl.TextColor3=Color3.fromRGB(180,255,220)
	elseif entry.isPriority then
		rd.rankBadge.BackgroundColor3=Color3.fromRGB(255,160,40)
		rd.stroke.Color=Color3.fromRGB(255,180,60); rd.stroke.Transparency=0.2; rd.stroke.Thickness=1.2
		rd.row.BackgroundColor3=Color3.fromRGB(16,9,32); rd.nameLbl.TextColor3=Color3.fromRGB(255,230,180)
	else
		rd.rankBadge.BackgroundColor3=Color3.fromRGB(80,40,160)
		rd.stroke.Color=Color3.fromRGB(80,40,160); rd.stroke.Transparency=0.4; rd.stroke.Thickness=1.2
		rd.row.BackgroundColor3=Color3.fromRGB(16,9,32); rd.nameLbl.TextColor3=Color3.fromRGB(235,225,255)
	end
end

refreshStealTargets=function()
	local _,allVisible=collectBrainrots()
	table.sort(allVisible,function(a,b)
		if a.income==b.income then return a.name<b.name end; return a.income>b.income
	end)

	local combined,usedUIDs={},{}
	for _,wn in ipairs(State.priorityList) do
		for _,p in ipairs(allVisible) do
			if p.name==wn and not usedUIDs[p.uid] then
				usedUIDs[p.uid]=true
				table.insert(combined,{name=p.name,income=p.income,isPriority=true,prompt=p.prompt,mutation=p.mutation,uid=p.uid})
			end
		end
	end
	for _,p in ipairs(allVisible) do
		if not usedUIDs[p.uid] then
			usedUIDs[p.uid]=true
			table.insert(combined,{name=p.name,income=p.income,isPriority=false,prompt=p.prompt,mutation=p.mutation,uid=p.uid})
		end
	end

	local count=#combined
	while #rowPool<count do table.insert(rowPool,createRow(#rowPool+1)) end

	for i,rd in ipairs(rowPool) do
		if i<=count then
			rd.row.LayoutOrder=i; rd.row.Visible=true
			applyRow(rd,combined[i],i)
		else
			rd.row.Visible=false; rd.entryUID=nil; rd.entryName=nil
		end
	end

	local totalH=count*(ROW_H2+ROW_GAP)-ROW_GAP
	stScrollFrame.CanvasSize=UDim2.new(0,0,0,math.max(0,totalH+4))
	stEmptyLbl.Visible=(count==0)
end

task.spawn(function()
	while true do
		if not State.guiClosed then refreshStealTargets() end
		task.wait(2)
	end
end)

-- ═══════════ PRIORITY LIST POPUP ═══════════
local function isInPriority(name)
	for _,n in ipairs(State.priorityList) do if n==name then return true end end; return false
end
local function removeFromPriority(name)
	for i,n in ipairs(State.priorityList) do if n==name then table.remove(State.priorityList,i); return end end
end
local function addToPriority(name)
	if not isInPriority(name) then table.insert(State.priorityList,name) end
end
local function moveInPriority(name,dir)
	for i,n in ipairs(State.priorityList) do
		if n==name then
			local ni=i+dir
			if ni>=1 and ni<=#State.priorityList then State.priorityList[i]=State.priorityList[ni]; State.priorityList[ni]=name end
			return
		end
	end
end

