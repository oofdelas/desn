local function setAutoGrab(on)
	State.autoStealEnabled=on
	if on then
		toggleBtn.Text="▶  AUTO GRAB ● RUNNING"; toggleBtn.TextColor3=Color3.fromRGB(140,255,180)
		tPill.BackgroundColor3=Color3.fromRGB(60,220,130); Tween(tStr,.2,{Color=Color3.fromRGB(60,220,130),Transparency=0.3})
		statusText.Text="Scanning..."; statusText.TextColor3=Color3.fromRGB(235,225,255)
		statusDot.BackgroundColor3=Color3.fromRGB(180,120,255)
	else
		toggleBtn.Text="❚❚  AUTO GRAB ● PAUSED"; toggleBtn.TextColor3=Color3.fromRGB(255,100,100)
		tPill.BackgroundColor3=Color3.fromRGB(230,60,60); Tween(tStr,.2,{Color=Color3.fromRGB(220,50,50),Transparency=0.35})
		statusText.Text="Paused"; statusText.TextColor3=Color3.fromRGB(255,90,90)
		statusDot.BackgroundColor3=Color3.fromRGB(255,60,60)
		progressFill.Size=UDim2.new(0,0,1,0)
	end
end

local function executeSteal(prompt)
	if State.isStealing or not prompt or not prompt.Parent then return end
	State.isStealing=true; State.selectionChanged=false
	statusText.Text="Stealing: "..(prompt.ObjectText or "?")
	statusText.TextColor3=Color3.fromRGB(195,135,255); statusDot.BackgroundColor3=Color3.fromRGB(180,100,255)
	fireConn(prompt,"PromptButtonHoldBegan")
	progressFill.Size=UDim2.new(0,0,1,0)
	local tw=TweenService:Create(progressFill,TweenInfo.new(State.stealDelay,Enum.EasingStyle.Linear),{Size=UDim2.new(1,0,1,0)})
	tw:Play()
	local elapsed,step=0,0.05
	while elapsed<State.stealDelay do
		task.wait(step); elapsed=elapsed+step
		if State.selectionChanged then tw:Cancel(); progressFill.Size=UDim2.new(0,0,1,0); State.isStealing=false; State.selectionChanged=false; return end
	end
	if prompt and prompt.Parent and prompt.Enabled and not State.selectionChanged then fireConn(prompt,"Triggered") end
	progressFill.Size=UDim2.new(0,0,1,0); State.isStealing=false
end

