local function getTarget()
	local all,_=collectBrainrots()
	if #all==0 then return nil end

	-- FIX bug 2: busca pelo uid exato
	if State.selectedUID then
		for _,p in ipairs(all) do
			if p.uid==State.selectedUID then return p.prompt end
		end
		return nil
	end

	if State.method==1 then
		local best,bd=nil,150
		for _,p in ipairs(all) do if p.dist<bd then bd=p.dist; best=p.prompt end end
		return best
	elseif State.method==2 then
		for _,wn in ipairs(State.priorityList) do
			local bp,bi=nil,-1
			for _,p in ipairs(all) do if p.name==wn and p.income>bi then bi=p.income; bp=p.prompt end end
			if bp then return bp end
		end
		return nil
	elseif State.method==3 then
		local best,bg=nil,-1
		for _,p in ipairs(all) do if p.income>bg then bg=p.income; best=p.prompt end end
		return best
	end
end

