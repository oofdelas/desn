local function rebuildLayout(minimized)
	local y = HEADER_Y+HEADER_H+6+1+8  -- após sep1

	if minimized then
		-- esconde tudo menos header e discord
		for i=1,3 do tabFrames[i].Visible=false end
		editListBtn.Visible=false
		statusCard.Visible=false
		toggleBtn.Visible=false
		pbBg.Visible=false
		sep2.Visible=false
		stScrollFrame.Visible=false
		stEmptyLbl.Visible=false
		discBar.Visible=true
		discBar.Position=UDim2.new(0,PAD,0,y)
		local totalH=y+34+8
		Tween(main,.25,{Size=UDim2.new(1,-20,0,totalH)})
		Tween(wrap,.25,{Size=UDim2.new(0,340,0,totalH+20)})
		return
	end

	-- mostra tudo
	for i=1,3 do tabFrames[i].Visible=true end
	statusCard.Visible=true
	toggleBtn.Visible=true
	pbBg.Visible=true
	sep2.Visible=true
	stScrollFrame.Visible=true
	discBar.Visible=true

	-- tabs
	for i=1,3 do
		local x=PAD+(TAB_W+TAB_GAP)*(i-1)
		tabFrames[i].Position=UDim2.new(0,x,0,y)
	end
	y=y+32+8

	-- edit priority btn (só se método 2)
	if State.method==2 then
		editListBtn.Position=UDim2.new(0,PAD,0,y)
		editListBtn.Visible=true
		y=y+28+8
	else
		editListBtn.Visible=false
	end

	-- status
	statusCard.Position=UDim2.new(0,PAD,0,y); y=y+44+8

	-- toggle
	toggleBtn.Position=UDim2.new(0,PAD,0,y); y=y+36+6

	-- progress
	pbBg.Position=UDim2.new(0,PAD,0,y); y=y+6+10

	-- sep2
	sep2.Position=UDim2.new(0,PAD,0,y); y=y+1+10

	-- scroll list
	stScrollFrame.Position=UDim2.new(0,PAD,0,y)
	stEmptyLbl.Position=UDim2.new(0,PAD,0,y+40)
	y=y+SCROLL_H+10

	-- discord
	discBar.Position=UDim2.new(0,PAD,0,y); y=y+34+8

	local totalH=y
	Tween(main,.25,{Size=UDim2.new(1,-20,0,totalH)})
	Tween(wrap,.25,{Size=UDim2.new(0,340,0,totalH+20)})
end

