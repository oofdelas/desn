local function getIncomeFromData(name)
	if not AnimalsData or not name then return 0 end
	local data = AnimalsData[name]
	if not data then
		for k,v in pairs(AnimalsData) do
			if type(k)=="string" and string.lower(k)==string.lower(name) then data=v; break end
			if type(v)=="table" and v.Name and string.lower(tostring(v.Name))==string.lower(name) then data=v; break end
		end
	end
	if type(data)=="table" then
		local val = data.ProduceMoney or data.Income or data.Generation or data.Gen or data.Produce or data.Money or data.Earnings or data.Rate
		if type(val)=="number" then return val end
		if val then return tonumber(val) or 0 end
	end
	return 0
end

local function getPromptData(prompt, name)
	if not AnimalsShared or not name then return getIncomeFromData(name), nil end
	local plot = prompt.Parent
	for _=1,10 do
		if not plot then break end
		if plot.Parent and plot.Parent.Name=="Plots" then break end
		plot = plot.Parent
	end
	if not plot then return getIncomeFromData(name), nil end
	local promptPos
	if prompt.Parent and prompt.Parent:IsA("Attachment") then promptPos=prompt.Parent.WorldPosition
	elseif prompt.Parent and prompt.Parent:IsA("BasePart") then promptPos=prompt.Parent.Position end
	local candidates={}
	for _,c in ipairs(plot:GetChildren()) do
		if c:IsA("Model") and c.Name==name then table.insert(candidates,c) end
	end
	if #candidates==0 then return getIncomeFromData(name), nil end
	local model
	if promptPos and #candidates>1 then
		local bd=math.huge
		for _,m in ipairs(candidates) do
			local pp=m.PrimaryPart or m:FindFirstChildWhichIsA("BasePart")
			if pp then local d=(pp.Position-promptPos).Magnitude; if d<bd then bd=d; model=m end end
		end
		if not model then model=candidates[1] end
	else model=candidates[1] end
	if not model then return getIncomeFromData(name), nil end
	local mut = model:GetAttribute("Mutation") or model:GetAttribute("__mutation")
	local traitsStr = model:GetAttribute("Traits") or model:GetAttribute("__traits") or ""
	local traits={}
	if traitsStr~="" then
		for t in traitsStr:gmatch("[^,]+") do
			local tr=t:match("^%s*(.-)%s*$"); if tr~="" then table.insert(traits,tr) end
		end
	end
	local mc = mut; if mut=="" or mut=="None" or mut=="none" then mc=nil end
	local ok,gen = pcall(function() return AnimalsShared:GetGeneration(name,mc,traits,nil) end)
	local income = (ok and gen and gen>0) and gen or getIncomeFromData(name)
	return income, mut
end

local function getAllBrainrots()
	local result={}
	if type(AnimalsData)~="table" then return result end
	local list={}
	for key,data in pairs(AnimalsData) do
		if type(data)=="table" then
			local n=data.Name or data.DisplayName or key
			local v=data.ProduceMoney or data.Price or data.Income or data.Generation or data.Gen or data.Value or data.Cost or data.Rate or 0
			if type(v)~="number" then v=tonumber(v) or 0 end
			table.insert(list,{name=tostring(n),value=v})
		elseif type(data)=="string" then table.insert(list,{name=data,value=0}) end
	end
	table.sort(list,function(a,b) if a.value==b.value then return a.name<b.name end; return a.value>b.value end)
	for _,item in ipairs(list) do table.insert(result,item.name) end
	return result
end

local function isMyPlot(plot)
	if not plot then return false end
	local sign=plot:FindFirstChild("PlotSign")
	if sign then
		local yb=sign:FindFirstChild("YourBase")
		if yb and yb:IsA("BillboardGui") and yb.Enabled then return true end
	end
	return false
end

local function getRootPart()
	local char=LocalPlayer.Character
	return char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("UpperTorso"))
end

local function isValidPrompt(prompt)
	if not prompt or not prompt.Parent then return false end
	if not prompt.Enabled then return false end
	local st=prompt:GetAttribute("State"); local at=prompt.ActionText
	if st~=nil then return st=="Steal" or st=="Grab" end
	if at=="Steal" or at=="Grab" then return true end
	return prompt.Enabled
end

local function collectBrainrots()
	local stealable,allVisible={},{}
	local root=getRootPart()
	local plots=Workspace:FindFirstChild("Plots")
	if not plots then return stealable,allVisible end
	for _,plot in ipairs(plots:GetChildren()) do
		if isMyPlot(plot) then continue end
		local podiums=plot:FindFirstChild("AnimalPodiums")
		if not podiums then continue end
		for _,podium in ipairs(podiums:GetChildren()) do
			local base=podium:FindFirstChild("Base")
			local sp=base and base:FindFirstChild("Spawn")
			local att=sp and sp:FindFirstChild("PromptAttachment")
			if not att then continue end
			for _,child in ipairs(att:GetChildren()) do
				if not child:IsA("ProximityPrompt") then continue end
				local name=child.ObjectText or ""
				if name=="" then continue end
				local dist=root and (root.Position-child.Parent.WorldPosition).Magnitude or 999
				local income,mut=getPromptData(child,name)
				local sf=isValidPrompt(child)
				local uid=tostring(podium).."_"..name
				local entry={prompt=child,dist=dist,name=name,income=income,mutation=mut,isStealable=sf,uid=uid}
				table.insert(allVisible,entry)
				if sf then table.insert(stealable,entry) end
			end
		end
	end
	return stealable,allVisible
end

