local function formatMoney(n)
	if NumberUtils then
		local ok, r = pcall(function()
			if type(NumberUtils.FormatNumber)=="function" then return NumberUtils.FormatNumber(n) end
			if type(NumberUtils.Format)=="function" then return NumberUtils.Format(n) end
			if type(NumberUtils.Short)=="function" then return NumberUtils.Short(n) end
			if type(NumberUtils.toShort)=="function" then return NumberUtils.toShort(n) end
			if type(NumberUtils.ToString)=="function" then return NumberUtils.ToString(n) end
		end)
		if ok and r then return tostring(r) end
	end
	if n>=1e12 then return string.format("%.2fT",n/1e12)
	elseif n>=1e9 then return string.format("%.2fB",n/1e9)
	elseif n>=1e6 then return string.format("%.2fM",n/1e6)
	elseif n>=1e3 then return string.format("%.1fK",n/1e3)
	else return tostring(math.floor(n)) end
end

