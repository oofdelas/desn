-- Carrega config ANTES de criar a UI
local function loadConfig()
    if isfile(configFile) then
        local success, data = pcall(function()
            return HttpService:JSONDecode(readfile(configFile))
        end)
        if success and data then
            if data.Keybind then
                local ok, kc = pcall(function()
                    return Enum.KeyCode[data.Keybind]
                end)
                if ok and kc then
                    State.keybind = kc
                end
            end
            return UDim2.new(
                data.X or 0.5, data.XOffset or -135,
                data.Y or 0.3, data.YOffset or 0
            )
        end
    end
    return UDim2.new(0.5, -135, 0.3, 0)
end

local savedPos = loadConfig()

--// DESYNC HOOKS
local function send_hook(packet)
    if not State.stealing or not State.desync or not State.desyncEnabled then return end
    if packet.PacketId == 0x1B then
        local b = packet.AsBuffer
        buffer.writeu32(b, 1, 0xFFFFFFFF)
        buffer.writeu32(b, 5, 0xFFFFFFFF)
        buffer.writeu32(b, 9, 0xFFFFFFFF)
        packet:SetData(b)
    end
end

local function recv_hook(packet)
    if not State.stealing or not State.desync or not State.desyncEnabled then return end
    if packet.PacketId == 0x1B or packet.PacketId == 0x86 then packet:Drop() end
end

pcall(function()
    if raknet.add_send_hook then raknet.add_send_hook(send_hook) end
    if raknet.add_recv_hook then raknet.add_recv_hook(recv_hook) end
end)

