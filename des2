--// CORE LOGIC
task.spawn(function()
    while true do
        local isStealing = lp:GetAttribute("Stealing") == true

        if not isStealing then
            State.stealing = false
            State.desync = false
            State.timer = 5
            statusText.Text = "Waiting..."
            statusText.TextColor3 = Color3.fromRGB(200, 200, 200)
            statusDot.BackgroundColor3 = Color3.fromRGB(255, 70, 70)
        else
            State.stealing = true
            State.desync = true

            task.wait(0.5)

            if lp:GetAttribute("Stealing") == true then
                doRollback()
            end

            while State.timer > 0 and lp:GetAttribute("Stealing") == true do
                statusText.Text = string.format("%.1fs", State.timer)
                statusText.TextColor3 = Color3.fromRGB(190, 120, 255)
                statusDot.BackgroundColor3 = Color3.fromRGB(190, 120, 255)
                task.wait(0.1)
                State.timer = State.timer - 0.1
            end

            if lp:GetAttribute("Stealing") == true then
                State.desync = false
                statusText.Text = "Syncing..."
                statusText.TextColor3 = Color3.fromRGB(150, 80, 255)

                local char = lp.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local p = hrp.CFrame
                    hrp.CFrame = p * CFrame.new(0, 1000, 0)
                    task.wait(0.05)
                    hrp.CFrame = p
                end

                task.wait(0.15)
                State.desync = true
                State.timer = 5
            end
        end

        task.wait(0.05)
    end
end)

