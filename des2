local function makeBtn(text, yPos, w, xPos, textColor)
    local btn = Instance.new("TextButton", main)
    btn.Size = w or UDim2.new(0.88, 0, 0, 40)
    btn.Position = xPos or UDim2.new(0.06, 0, 0, yPos)
    btn.BackgroundColor3 = Color3.fromRGB(22, 13, 40)
    btn.Text = text
    btn.TextColor3 = textColor or Color3.fromRGB(200, 160, 255)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 13
    btn.BorderSizePixel = 0
    btn.AutoButtonColor = false
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10)

    local stroke = Instance.new("UIStroke", btn)
    stroke.Color = Color3.fromRGB(90, 45, 170)
    stroke.Transparency = 0.55

    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.18), {BackgroundColor3 = Color3.fromRGB(42, 22, 75)}):Play()
        TweenService:Create(stroke, TweenInfo.new(0.18), {Transparency = 0.1}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.18), {BackgroundColor3 = Color3.fromRGB(22, 13, 40)}):Play()
        TweenService:Create(stroke, TweenInfo.new(0.18), {Transparency = 0.55}):Play()
    end)

    return btn, stroke
end

