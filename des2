local function MakeBtn(labelText,yPos,accentColor,textColor)
	accentColor = accentColor or Color3.fromRGB(140,60,255)
	textColor   = textColor   or Color3.fromRGB(220,180,255)
	local frame=Instance.new("Frame",main)
	frame.Size=UDim2.new(0,INNER,0,44); frame.Position=UDim2.new(0,PAD,0,yPos)
	frame.BackgroundColor3=Color3.fromRGB(16,9,32); frame.BorderSizePixel=0; frame.ZIndex=5; frame.ClipsDescendants=true
	Instance.new("UICorner",frame).CornerRadius=UDim.new(0,12)
	local fGrad=Instance.new("UIGradient",frame)
	fGrad.Color=ColorSequence.new{ColorSequenceKeypoint.new(0,Color3.fromRGB(28,14,60)),ColorSequenceKeypoint.new(1,Color3.fromRGB(12,6,26))}; fGrad.Rotation=90
	local fs=Instance.new("UIStroke",frame); fs.Color=accentColor; fs.Thickness=1.2; fs.Transparency=0.5; fs.ApplyStrokeMode=Enum.ApplyStrokeMode.Border
	local pill=Instance.new("Frame",frame); pill.Size=UDim2.fromOffset(3,22); pill.Position=UDim2.new(0,10,0.5,-11)
	pill.BackgroundColor3=accentColor; pill.BorderSizePixel=0; pill.ZIndex=7
	Instance.new("UICorner",pill).CornerRadius=UDim.new(0,3)
	local shine=Instance.new("Frame",frame); shine.Size=UDim2.new(0,60,1,0); shine.Position=UDim2.new(0,-80,0,0)
	shine.BackgroundColor3=accentColor; shine.BorderSizePixel=0; shine.ZIndex=6
	local shG=Instance.new("UIGradient",shine)
	shG.Transparency=NumberSequence.new{NumberSequenceKeypoint.new(0,1),NumberSequenceKeypoint.new(0.5,0.75),NumberSequenceKeypoint.new(1,1)}
	local btn=Instance.new("TextButton",frame); btn.Size=UDim2.new(1,0,1,0); btn.BackgroundTransparency=1
	btn.Text=labelText; btn.TextColor3=textColor; btn.Font=Enum.Font.GothamBold; btn.TextSize=13
	btn.BorderSizePixel=0; btn.ZIndex=8; btn.AutoButtonColor=false
	btn.MouseEnter:Connect(function()
		Tween(frame,.2,{BackgroundColor3=Color3.fromRGB(32,16,68)}); Tween(fs,.2,{Transparency=0,Color=accentColor})
		Tween(pill,.2,{Size=UDim2.fromOffset(4,28),Position=UDim2.new(0,10,0.5,-14)})
		shine.Position=UDim2.new(0,-80,0,0); Tween(shine,0.6,{Position=UDim2.new(1,20,0,0)},Enum.EasingStyle.Quart)
	end)
	btn.MouseLeave:Connect(function()
		Tween(frame,.2,{BackgroundColor3=Color3.fromRGB(16,9,32)}); Tween(fs,.2,{Transparency=0.5,Color=accentColor})
		Tween(pill,.2,{Size=UDim2.fromOffset(3,22),Position=UDim2.new(0,10,0.5,-11)})
	end)
	btn.MouseButton1Down:Connect(function() Tween(frame,.07,{BackgroundColor3=Color3.fromRGB(45,22,90)}) end)
	btn.MouseButton1Up:Connect(function()   Tween(frame,.12,{BackgroundColor3=Color3.fromRGB(32,16,68)}) end)
	return btn,frame,fs,pill
end

