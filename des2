local function updateSlider(absX)
    local tbAbs = trackBG.AbsolutePosition.X
    local tbW   = trackBG.AbsoluteSize.X
    local pct   = math.clamp((absX - tbAbs) / tbW, 0, 1)
    local raw     = 1 + pct * 7
    local snapped = math.round(raw)
    snapped = math.clamp(snapped, 1, 8)
    State.maxTimer = snapped
    State.timer    = snapped
    local p2 = (snapped - 1) / 7
    Tween(trackFill, 0.15, {Size = UDim2.new(p2, 0, 1, 0)})
    Tween(thumb, 0.15, {Position = UDim2.new(p2, 0, 0.5, 0)})
    slVal.Text = string.format("%ds", snapped)
    if timerValueLabel then timerValueLabel.Text = string.format("%ds", snapped) end
    SaveConfig()
