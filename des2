local function doRollback()
	local char = lp.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end

	serverPos = hrp.Position

	if State.method == 1 then
		if not lastSafePos then return end
		hrp.CFrame = CFrame.new(lastSafePos)

	elseif State.method == 2 then
		if not lastSafePos then return end
		hrp.Velocity                = Vector3.zero
		hrp.AssemblyLinearVelocity  = Vector3.zero
		hrp.AssemblyAngularVelocity = Vector3.zero
		hrp.CFrame = CFrame.new(lastSafePos)

	elseif State.method == 3 then
		if not freezePos then freezePos = hrp.Position end
		hrp.CFrame = CFrame.new(freezePos)
		serverPos = freezePos
		return
	end

	State.timer = State.maxTimer
	if statusText then
		statusText.Text       = string.format("%.1fs", State.timer)
		statusText.TextColor3 = Color3.fromRGB(180, 120, 255)
	end
	if statusDot then statusDot.BackgroundColor3 = Color3.fromRGB(180, 120, 255) end
end

pcall(function()
	raknet.add_send_hook(function(p)
		if not State.enabled then return end

		if State.method == 3 then
			if p.PacketId == 0x1B then
				if os.clock() - lastFreezeUpdate >= FREEZE_INTERVAL then
					lastFreezeUpdate = os.clock()
					local char = lp.Character
					local hrp = char and char:FindFirstChild("HumanoidRootPart")
					if hrp then
						freezePos = hrp.Position
						serverPos = freezePos
					end
				else
					local b = p.AsBuffer
					buffer.writeu32(b, 1, 0xFFFFFFFF)
					buffer.writeu32(b, 5, 0xFFFFFFFF)
					buffer.writeu32(b, 9, 0xFFFFFFFF)
					p:SetData(b)
				end
			end
			return
		end

		if not State.stealing or not State.desync then return end
		if p.PacketId == 0x1B then
			local b = p.AsBuffer
			buffer.writeu32(b, 1, 0xFFFFFFFF)
			buffer.writeu32(b, 5, 0xFFFFFFFF)
			buffer.writeu32(b, 9, 0xFFFFFFFF)
			p:SetData(b)
		end
	end)
	raknet.add_recv_hook(function(p)
		if not State.enabled then return end
		if State.method == 3 then
			if p.PacketId == 0x1B or p.PacketId == 0x86 or p.PacketId == 0x21 then p:Drop() end
			return
		end
		if not State.stealing or not State.desync then return end
		if p.PacketId == 0x1B or p.PacketId == 0x86 or p.PacketId == 0x21 then p:Drop() end
	end)
end)

local function Tween(obj, t, props, style, dir)
	style = style or Enum.EasingStyle.Quart
	dir = dir or Enum.EasingDirection.Out
	TweenService:Create(obj, TweenInfo.new(t, style, dir), props):Play()
end

local function AnimGradient(obj, speed, colors)
	speed = speed or 0.008
	colors = colors or ColorSequence.new{
		ColorSequenceKeypoint.new(0,    Color3.fromRGB( 80, 20, 200)),
		ColorSequenceKeypoint.new(0.25, Color3.fromRGB(200,100, 255)),
		ColorSequenceKeypoint.new(0.5,  Color3.fromRGB(120, 40, 255)),
		ColorSequenceKeypoint.new(0.75, Color3.fromRGB(220,140, 255)),
		ColorSequenceKeypoint.new(1,    Color3.fromRGB( 80, 20, 200)),
	}
	local g = Instance.new("UIGradient", obj)
	g.Color = colors
	task.spawn(function()
		local o = 0
		while obj and obj.Parent do
			o = (o + speed) % 1
			g.Offset = Vector2.new(o, 0)
			task.wait(0.03)
		end
	end)
	return g
end

