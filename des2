-- ════════════════════════════════════
--  MAIN LOOP
-- ════════════════════════════════════
task.spawn(function()
    while true do
        local isStealing=lp:GetAttribute("Stealing")==true

        if not isStealing or not State.enabled then
            State.stealing=false; State.desync=false; State.isDelaying=false
            State.timer=State.maxTimer
            if statusText then
                statusText.Text  = State.enabled and "Waiting..." or "Disabled"
                statusText.TextColor3 = State.enabled and Color3.fromRGB(200,200,225) or Color3.fromRGB(255,90,90)
            end
            if statusDot then statusDot.BackgroundColor3=Color3.fromRGB(255,60,60) end
            if statusChipLabel and State.enabled then
                statusChipLabel.Text="OFF"; statusChipLabel.TextColor3=Color3.fromRGB(255,100,100)
            end

        elseif not State.isDelaying then
            State.isDelaying=true; State.stealing=true; State.desync=true

            if statusChipLabel then
                statusChipLabel.Text="ON"; statusChipLabel.TextColor3=Color3.fromRGB(140,255,180)
            end
            if statusDot then statusDot.BackgroundColor3=Color3.fromRGB(180,100,255) end

            task.wait(0.5)
            if lp:GetAttribute("Stealing")==true then doRollback() end

            while State.timer>0 and lp:GetAttribute("Stealing")==true and State.enabled do
                if statusText then
                    statusText.Text=string.format("%.1fs",State.timer)
                    statusText.TextColor3=Color3.fromRGB(195,135,255)
                end
                if statusDot then statusDot.BackgroundColor3=Color3.fromRGB(180,100,255) end
                task.wait(0.1); State.timer=math.max(0,State.timer-0.1)
            end

            if lp:GetAttribute("Stealing")==true and State.enabled then
                State.desync=false
                if statusText then statusText.Text="Syncing..."; statusText.TextColor3=Color3.fromRGB(160,90,255) end
                local hrp=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local cur=hrp.CFrame; hrp.CFrame=cur*CFrame.new(0,1000,0)
                    task.wait(0.05); hrp.CFrame=cur
                end
                task.wait(0.15); doRollback(); task.wait(0.05); State.desync=true
            end
            State.isDelaying=false
        end
        task.wait(0.05)
    end
end)

