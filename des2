UIS.InputBegan:Connect(function(input, gpe)
    if State.listeningForKey then
        if input.UserInputType == Enum.UserInputType.Keyboard then
            if input.KeyCode == Enum.KeyCode.Escape then
                State.listeningForKey = false
                local kn = State.keybind.Name
                keybindBadge.Text = #kn > 3 and kn:sub(1, 3) or kn
                TweenService:Create(keybindBadge, TweenInfo.new(0.18), {BackgroundColor3 = Color3.fromRGB(80, 30, 160)}):Play()
                TweenService:Create(keybindStroke, TweenInfo.new(0.18), {Color = Color3.fromRGB(160, 80, 255)}):Play()
                return
            end

            State.keybind = input.KeyCode
            State.listeningForKey = false

            local keyName = input.KeyCode.Name
            keybindBadge.Text = #keyName > 3 and keyName:sub(1, 3) or keyName

            TweenService:Create(keybindBadge, TweenInfo.new(0.18), {BackgroundColor3 = Color3.fromRGB(80, 30, 160)}):Play()
            TweenService:Create(keybindStroke, TweenInfo.new(0.18), {Color = Color3.fromRGB(160, 80, 255)}):Play()

            saveConfig()
        end
        return
    end

    if gpe then return end
    if input.KeyCode == State.keybind then doRollback() end
end)

