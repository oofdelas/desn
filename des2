local function Tween(obj, t, props, style, dir)
    style = style or Enum.EasingStyle.Quart
    dir   = dir   or Enum.EasingDirection.Out
    TweenService:Create(obj, TweenInfo.new(t, style, dir), props):Play()
end

local function ApplyAnimatedGradient(obj, speed, colors)
    speed  = speed or 0.008
    colors = colors or ColorSequence.new{
        ColorSequenceKeypoint.new(0,    Color3.fromRGB(80, 20, 200)),
        ColorSequenceKeypoint.new(0.25, Color3.fromRGB(200,100,255)),
        ColorSequenceKeypoint.new(0.5,  Color3.fromRGB(120, 40,255)),
        ColorSequenceKeypoint.new(0.75, Color3.fromRGB(220,140,255)),
        ColorSequenceKeypoint.new(1,    Color3.fromRGB(80, 20, 200)),
    }
    local g = Instance.new("UIGradient", obj)
    g.Color = colors
    task.spawn(function()
        local o = 0
        while obj and obj.Parent do
            o = (o + speed) % 1
            g.Offset = Vector2.new(o, 0)
            task.wait(0.03)
        end
    end)
    return g
end

