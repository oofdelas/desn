local CFG_FOLDER = "AlbuxHub_V6"
local CFG_FILE   = CFG_FOLDER .. "/config.json"
if not isfolder(CFG_FOLDER) then makefolder(CFG_FOLDER) end

local function LoadConfig()
    if isfile and isfile(CFG_FILE) then
        local ok, d = pcall(function() return HttpService:JSONDecode(readfile(CFG_FILE)) end)
        if ok and d then
            if d.Keybind then
                local kok, kc = pcall(function() return Enum.KeyCode[d.Keybind] end)
                if kok and kc then State.keybind = kc end
            end
            if d.MaxTimer then
                State.maxTimer = math.clamp(d.MaxTimer, 1, 8)
                State.timer    = State.maxTimer
            end
            return UDim2.new(d.X or 0.5, d.XO or -160, d.Y or 0.3, d.YO or 0)
        end
    end
    return UDim2.new(0.5, -160, 0.3, 0)
end

local savedPos = LoadConfig()

local function SaveConfig()
    pcall(function()
        writefile(CFG_FILE, HttpService:JSONEncode({
            X        = wrap.Position.X.Scale,
            XO       = wrap.Position.X.Offset,
            Y        = wrap.Position.Y.Scale,
            YO       = wrap.Position.Y.Offset,
            Keybind  = State.keybind.Name,
            MaxTimer = State.maxTimer,
        }))
    end)
end

