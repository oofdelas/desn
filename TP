local function tweenWaitUntil(cond, timeout)
    local deadline = os.clock() + (timeout or 10)
    while os.clock() < deadline do
        if cond() then return true end
        RunService.Heartbeat:Wait()
    end
    return false
end

local function tweenZeroVel(hrp)
    if not hrp or not hrp.Parent then return end
    hrp.AssemblyLinearVelocity  = Vector3.zero
    hrp.AssemblyAngularVelocity = Vector3.zero
end

local function tweenEquipCarpet(hum, char)
    if not hum or not char then return end
    local c = LocalPlayer.Backpack:FindFirstChild(Config.Tool) or char:FindFirstChild(Config.Tool)
    if c then pcall(function() hum:EquipTool(c) end) end
end

local function tweenGetFlySpeed(elapsed)
    local t = math.clamp(elapsed / 1.5, 0, 1)
    local ease = 1 - (1 - t) * (1 - t)
    return 130 + (150 - 130) * ease
end

local function tweenFlyTo(hrp, goal, timeout)
    timeout = timeout or 15
    local started = os.clock()
    local char = hrp.Parent
    while hrp.Parent do
        local elapsed = os.clock() - started
        local offset  = goal - hrp.Position
        if offset.Magnitude <= 1.5 then break end
        if elapsed >= timeout then break end
        hrp.AssemblyLinearVelocity = offset.Unit * tweenGetFlySpeed(elapsed)
        RunService.Heartbeat:Wait()
    end
    tweenZeroVel(hrp)
    if char and char.Parent then
        local rot = hrp.CFrame - hrp.Position
        hrp.CFrame = CFrame.new(goal) * rot
        tweenZeroVel(hrp)
    end
end

local function tweenFlySmooth(hrp, hum, goal, speed, timeout)
    speed   = speed   or 150
    timeout = timeout or 15
    local char    = hrp.Parent
    local started = os.clock()

    tweenEquipCarpet(hum, char)

    local carpetHold = RunService.Heartbeat:Connect(function()
        if not char or not char.Parent then return end
        if not char:FindFirstChild(Config.Tool) then
            local c = LocalPlayer.Backpack:FindFirstChild(Config.Tool) or char:FindFirstChild(Config.Tool)
            if c then pcall(function() hum:EquipTool(c) end) end
        end
    end)

    while hrp.Parent do
        local offset = goal - hrp.Position
        if offset.Magnitude <= 2 then break end
        if os.clock() - started >= timeout then break end
        if LocalPlayer:GetAttribute("Stealing") then break end
        hrp.AssemblyLinearVelocity = offset.Unit * speed
        RunService.Heartbeat:Wait()
    end

    carpetHold:Disconnect()
    tweenZeroVel(hrp)
end

local function tweenRaycastWall(hrp, char, range, strict)
    local origin = hrp.Position + Vector3.new(0, 2, 0)
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {char}
    local DIRS = {
        Vector3.new(1,0,0), Vector3.new(-1,0,0),
        Vector3.new(0,0,1), Vector3.new(0,0,-1),
        Vector3.new(1,0,1).Unit, Vector3.new(1,0,-1).Unit,
        Vector3.new(-1,0,1).Unit, Vector3.new(-1,0,-1).Unit,
    }
    local bestHit, bestDist = nil, range + 1
    for _, dir in ipairs(DIRS) do
        local hit = Workspace:Raycast(origin, dir * range, params)
        if hit and hit.Instance:IsA("BasePart") then
            local isWall = true
            if strict then
                local s = hit.Instance.Size
                isWall = math.max(s.X, s.Z) >= 2.5 and s.Y >= 1.5
            end
            if isWall then
                local d = (hit.Position - origin).Magnitude
                if d < bestDist then
                    bestDist = d
                    bestHit = {result=hit, dir=dir, origin=origin, hrp=hrp}
                end
            end
        end
    end
    return bestHit
end

local function tweenWallSnap(hit)
    local hrp    = hit.hrp
    local result = hit.result
    local normal = result.Normal
    local flatN  = Vector3.new(normal.X, 0, normal.Z)
    if flatN.Magnitude < 0.001 then
        flatN = Vector3.new(hit.dir.X, 0, hit.dir.Z).Unit
    else
        flatN = flatN.Unit
    end
    local toPlayer = Vector3.new(
        hrp.Position.X - result.Position.X, 0,
        hrp.Position.Z - result.Position.Z
    )
    if toPlayer.Magnitude > 0.05 and toPlayer:Dot(flatN) < 0 then
        flatN = -flatN
    end
    local half    = (math.abs(flatN.X) * hrp.Size.X + math.abs(flatN.Z) * hrp.Size.Z) * 0.5
    local snapPos = Vector3.new(result.Position.X, hrp.Position.Y, result.Position.Z) + flatN * (half + 0.35)
    return CFrame.lookAt(snapPos, snapPos - flatN)
end

local function tweenGetWallGoal(hrp, char)
    local hit = tweenRaycastWall(hrp, char, 4, true) or tweenRaycastWall(hrp, char, 4, false)
    if not hit then return nil end
    return tweenWallSnap(hit)
end

local function tweenApproachWall(char, hrp, hum)
    local hit = tweenRaycastWall(hrp, char, 4, true) or tweenRaycastWall(hrp, char, 4, false)
    if not hit then return end
    local snap = tweenWallSnap(hit)
    if not snap then return end

    local walkDir = Vector3.new(hit.dir.X, 0, hit.dir.Z)
    if walkDir.Magnitude < 0.05 then return end
    walkDir = walkDir.Unit

    local look = snap.LookVector
    look = Vector3.new(look.X, 0, look.Z)
    if look.Magnitude < 0.05 then look = walkDir else look = look.Unit end

    local wallDist = (hit.result.Position - hit.origin).Magnitude
    local half = (math.abs(walkDir.X) * hrp.Size.X + math.abs(walkDir.Z) * hrp.Size.Z) * 0.5
    local walkDist = math.clamp(wallDist - half - 0.35, 0, 4.5)

    if look.Magnitude > 0.05 then
        hrp.CFrame = CFrame.lookAt(hrp.Position, hrp.Position + look)
    end

    if walkDist >= 0.35 then
        hum:ChangeState(Enum.HumanoidStateType.Running)
        local ctrl = getControls()
        if ctrl then ctrl:Disable() end
        local startFlat = Vector3.new(hrp.Position.X, 0, hrp.Position.Z)
        local deadline  = os.clock() + math.clamp(walkDist / 18 + 0.25, 0.35, 0.85)
        while os.clock() < deadline do
            local nowFlat = Vector3.new(hrp.Position.X, 0, hrp.Position.Z)
            if (nowFlat - startFlat).Magnitude >= walkDist - 0.2 then break end
            hum:Move(walkDir, false)
            RunService.Heartbeat:Wait()
        end
        hum:Move(Vector3.zero, false)
        if ctrl then ctrl:Enable() end
        tweenZeroVel(hrp)
    end

    local cam = Workspace.CurrentCamera
    if cam then cam.CameraSubject = hum; cam.CameraType = Enum.CameraType.Custom end
end

