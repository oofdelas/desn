        hrp.AssemblyAngularVelocity = Vector3.zero
        hrp.CFrame = CFrame.new(finalPos) * facingRot
        hrp.AssemblyLinearVelocity  = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
    end

    if isSecondFloor then
        for _ = 1, 10 do
            hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 0, hrp.AssemblyLinearVelocity.Z)
            if (hrp.Position - targetBasePos).Magnitude > 3 then
                hrp.CFrame = CFrame.new(targetBasePos, targetBasePos + faceDir); sw(0.05)
            end
        end
        sw(0.05)
        do local newPos = hrp.Position + faceDir * 1; hrp.CFrame = CFrame.new(newPos, newPos + faceDir) end
        sw(0.06)
        hum.AutoRotate = false
