                local lname = desc.Name:lower()
                if lname:find("carpet") or lname:find("highway") or lname=="conveyor" or lname=="cyberconveyor" then
                    local part = _extractPartFromCarpet(desc)
                    if part then _lastCarpetX = part.Position.X; return part end
                end
            end
        end
    end
    local fallbackX = _lastCarpetX or -410
    if _fakeCarpetCache and _fakeCarpetCache.Parent then
        _fakeCarpetCache.Position = Vector3.new(fallbackX, 0, 0)
        return _fakeCarpetCache
    end
    local fake = Instance.new("Part")
    fake.Name="CarpetFallbackRef"; fake.Anchored=true; fake.CanCollide=false
    fake.Transparency=1; fake.Size=Vector3.new(1,1,1)
    fake.Position=Vector3.new(fallbackX,0,0); fake.Parent=Workspace
    _fakeCarpetCache = fake
    return fake
end

