local function CfgSlider(labelText, yPos, minV, maxV, curV, fmt, callback)
    local card = Instance.new("Frame", cfgMain)
    card.Size  = UDim2.new(0, CINNER, 0, 52)
    card.Position = UDim2.new(0, PAD, 0, yPos)
    card.BackgroundColor3 = Color3.fromRGB(16, 9, 32)
    card.BorderSizePixel  = 0; card.ZIndex = 5
    Instance.new("UICorner", card).CornerRadius = UDim.new(0, 10)
    local ss = Instance.new("UIStroke", card)
    ss.Color = Color3.fromRGB(100, 40, 200); ss.Thickness = 1.2; ss.Transparency = 0.4
    ss.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

    local topRow = Instance.new("Frame", card)
    topRow.Size  = UDim2.new(1, -16, 0, 16); topRow.Position = UDim2.new(0, 8, 0, 6)
    topRow.BackgroundTransparency = 1; topRow.ZIndex = 6

    local slLbl = Instance.new("TextLabel", topRow)
    slLbl.Size  = UDim2.new(0, 180, 1, 0); slLbl.BackgroundTransparency = 1
    slLbl.Text  = labelText; slLbl.Font = Enum.Font.GothamBold; slLbl.TextSize = 9
    slLbl.TextColor3 = Color3.fromRGB(140, 75, 210)
    slLbl.TextXAlignment = Enum.TextXAlignment.Left; slLbl.ZIndex = 7

    local slVal = Instance.new("TextLabel", topRow)
    slVal.Size  = UDim2.new(1, -180, 1, 0); slVal.Position = UDim2.new(0, 180, 0, 0)
    slVal.BackgroundTransparency = 1; slVal.Text = string.format(fmt, curV)
    slVal.Font  = Enum.Font.GothamBlack; slVal.TextSize = 12
    slVal.TextColor3 = Color3.fromRGB(220, 180, 255)
    slVal.TextXAlignment = Enum.TextXAlignment.Right; slVal.ZIndex = 7

    local trackBG = Instance.new("Frame", card)
    trackBG.Size  = UDim2.new(1, -16, 0, 7); trackBG.Position = UDim2.new(0, 8, 0, 32)
    trackBG.BackgroundColor3 = Color3.fromRGB(22, 10, 48)
    trackBG.BorderSizePixel  = 0; trackBG.ZIndex = 6
    Instance.new("UICorner", trackBG).CornerRadius = UDim.new(1, 0)

    local fillPct   = math.clamp((curV-minV)/(maxV-minV), 0, 1)
    local trackFill = Instance.new("Frame", trackBG)
    trackFill.Size  = UDim2.new(fillPct, 0, 1, 0)
    trackFill.BackgroundColor3 = Color3.fromRGB(160, 80, 255)
    trackFill.BorderSizePixel  = 0; trackFill.ZIndex = 7
    Instance.new("UICorner", trackFill).CornerRadius = UDim.new(1, 0)
    AnimGradient(trackFill, 0.012, ColorSequence.new{
        ColorSequenceKeypoint.new(0,   Color3.fromRGB(100, 30, 220)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(220, 140, 255)),
        ColorSequenceKeypoint.new(1,   Color3.fromRGB(100, 30, 220)),
    })

    local thumb = Instance.new("Frame", trackBG)
    thumb.Size  = UDim2.fromOffset(14, 14); thumb.AnchorPoint = Vector2.new(0.5, 0.5)
    thumb.Position = UDim2.new(fillPct, 0, 0.5, 0)
    thumb.BackgroundColor3 = Color3.fromRGB(220, 170, 255)
    thumb.BorderSizePixel  = 0; thumb.ZIndex = 9
    Instance.new("UICorner", thumb).CornerRadius = UDim.new(1, 0)

    local sliderBtn = Instance.new("TextButton", trackBG)
    sliderBtn.Size  = UDim2.new(1, 0, 3, 0); sliderBtn.Position = UDim2.new(0, 0, -1, 0)
    sliderBtn.BackgroundTransparency = 1; sliderBtn.Text = ""; sliderBtn.ZIndex = 10

    local dragging = false
    local function updateSlider(absX)
        local pct = math.clamp(
            (absX - trackBG.AbsolutePosition.X) / trackBG.AbsoluteSize.X, 0, 1)
        local v = minV + pct*(maxV-minV)
        Tween(trackFill, .12, {Size = UDim2.new(pct, 0, 1, 0)})
        Tween(thumb,     .12, {Position = UDim2.new(pct, 0, 0.5, 0)})
        slVal.Text = string.format(fmt, v)
        callback(v)
    end
    sliderBtn.MouseButton1Down:Connect(function()
        dragging = true; _sliderDragging2 = true
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement
            or i.UserInputType == Enum.UserInputType.Touch) then
            updateSlider(i.Position.X)
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1
        or i.UserInputType == Enum.UserInputType.Touch then
            dragging = false; _sliderDragging2 = false
        end
    end)
    return card
end

