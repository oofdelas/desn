local _priorityGui = nil

local function getBrainrotViewportClone(petName)
    if not petName or petName=="" then return nil end
    local modelsFolder = ReplicatedStorage:FindFirstChild("Models"); if not modelsFolder then return nil end
    local animalsFolder = modelsFolder:FindFirstChild("Animals"); if not animalsFolder then return nil end
    local srcModel = animalsFolder:FindFirstChild(petName); if not srcModel then return nil end
    local newVp = Instance.new("ViewportFrame")
    newVp.BackgroundTransparency = 1; newVp.BorderSizePixel = 0
    newVp.ImageColor3 = Color3.fromRGB(255,255,255); newVp.Visible = true
    local worldModel = Instance.new("WorldModel", newVp)
    local clonedModel = srcModel:Clone(); clonedModel.Parent = worldModel
    local animsRoot = ReplicatedStorage:FindFirstChild("Animations")
    local animalsAnims = animsRoot and animsRoot:FindFirstChild("Animals")
    local thisAnimFolder = animalsAnims and animalsAnims:FindFirstChild(petName)
    local idleAnim = thisAnimFolder and thisAnimFolder:FindFirstChild("Idle")
    if idleAnim and idleAnim:IsA("Animation") then
        local animator
        for _,d in ipairs(clonedModel:GetDescendants()) do
            if d:IsA("Animator") then animator=d; break end
        end
        if not animator then
            local ac = Instance.new("AnimationController", clonedModel)
            animator = Instance.new("Animator", ac)
        end
        if animator then
            local track = animator:LoadAnimation(idleAnim)
            if track then
                track.Looped = false
                local goingForward = true
                local function playDir()
                    if goingForward then track.TimePosition=0; track:AdjustSpeed(1)
                    else track.TimePosition=track.Length; track:AdjustSpeed(-1) end
                    track:Play()
                end
                track.Stopped:Connect(function() goingForward=not goingForward; playDir() end)
                playDir()
            end
        end
    end
    local cam = Instance.new("Camera", newVp); cam.Name = "BrainrotCamera"
    local cf, size = clonedModel:GetBoundingBox()
    clonedModel:PivotTo(cf * CFrame.Angles(0, math.rad(180), 0))
    cf = clonedModel:GetPivot()
    local maxSize = math.max(size.X, size.Y, size.Z)
    local dist    = math.max(maxSize * 0.8, 1.5)
    local camPos  = cf.Position
        + (cf.LookVector  * (dist * 1.2))
        + (cf.RightVector * (dist * 0.5))
        + (cf.UpVector    * (dist * 0.4))
    cam.CFrame = CFrame.new(camPos, cf.Position + cf.UpVector * (maxSize * 0.2))
    newVp.CurrentCamera = cam
    return newVp
end

local function createPriorityGUI()
    if _priorityGui and _priorityGui.Parent then
        _priorityGui:Destroy(); _priorityGui = nil; return
    end

    local popW, popH = 420, 580
    _priorityGui = Instance.new("ScreenGui")
    _priorityGui.Name = "LefaPriorityGUI"; _priorityGui.ResetOnSpawn = false
    _priorityGui.DisplayOrder = 100; _priorityGui.Parent = PlayerGui

    local borderFrame = Instance.new("Frame", _priorityGui)
    borderFrame.Size     = UDim2.fromOffset(popW+6, popH+6)
    borderFrame.Position = UDim2.new(0.5, -(popW+6)/2, 0.5, -(popH+6)/2)
    borderFrame.BackgroundColor3 = Color3.fromRGB(10,5,20); borderFrame.BorderSizePixel = 0
    Instance.new("UICorner", borderFrame).CornerRadius = UDim.new(0, 20)
    local bfStroke = Instance.new("UIStroke", borderFrame)
    bfStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    bfStroke.Thickness = 2; bfStroke.Color = Color3.fromRGB(200,150,255)

    local inner = Instance.new("Frame", borderFrame)
    inner.Size     = UDim2.new(1,-6,1,-6); inner.Position = UDim2.new(0,3,0,3)
    inner.BackgroundColor3 = Color3.fromRGB(10,5,20); inner.BorderSizePixel = 0
    Instance.new("UICorner", inner).CornerRadius = UDim.new(0,18)
    local innerBg = Instance.new("UIGradient", inner)
    innerBg.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(28,14,56)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(6,3,14)),
    }; innerBg.Rotation = 145

    local headerH = 40
    local popTitle = Instance.new("TextLabel", inner)
    popTitle.Size  = UDim2.new(1,0,0,headerH); popTitle.BackgroundTransparency=1
    popTitle.Text  = "PRIORITY LIST"; popTitle.Font=Enum.Font.GothamBlack; popTitle.TextSize=17
    popTitle.TextColor3 = Color3.fromRGB(220,180,255); popTitle.ZIndex=6

    local allNamesSet, allNames = {}, {}
    for _,name in ipairs(_allBrainrots) do
        if not allNamesSet[name] then allNamesSet[name]=true; table.insert(allNames,name) end
    end
    for _,name in ipairs(PRIORITY_LIST) do
        if not allNamesSet[name] then allNamesSet[name]=true; table.insert(allNames,name) end
    end
    table.sort(allNames, function(a,b) return a:lower()<b:lower() end)

    local priorityList  = {}; for _,n in ipairs(PRIORITY_LIST) do table.insert(priorityList,n) end
    local prioritySet   = {}; for _,n in ipairs(priorityList)  do prioritySet[n]=true end

    local TAB_H   = 34
    local scrollTop  = headerH + TAB_H + 20
    local closeH  = 40 + 10
    local scrollH = popH - scrollTop - closeH - 12

    local tabs = Instance.new("Frame", inner)
    tabs.Size  = UDim2.new(1,-24,0,TAB_H); tabs.Position = UDim2.new(0,12,0,headerH+4)
    tabs.BackgroundTransparency = 1

    local tabPrioBtn = Instance.new("TextButton", tabs)
    tabPrioBtn.Size  = UDim2.new(0.5,-4,1,0); tabPrioBtn.BackgroundColor3=Color3.fromRGB(50,18,110)
    tabPrioBtn.Text  = "Priority List"; tabPrioBtn.Font=Enum.Font.GothamBold; tabPrioBtn.TextSize=13
    tabPrioBtn.TextColor3=Color3.fromRGB(220,180,255); tabPrioBtn.AutoButtonColor=false
    tabPrioBtn.BorderSizePixel=0; tabPrioBtn.ZIndex=6
    Instance.new("UICorner",tabPrioBtn).CornerRadius=UDim.new(0,8)

    local tabAllBtn = Instance.new("TextButton", tabs)
    tabAllBtn.Size  = UDim2.new(0.5,-4,1,0); tabAllBtn.Position=UDim2.new(0.5,4,0,0)
    tabAllBtn.BackgroundColor3=Color3.fromRGB(16,9,32); tabAllBtn.Text="All Brainrots"
    tabAllBtn.Font=Enum.Font.GothamBold; tabAllBtn.TextSize=13
    tabAllBtn.TextColor3=Color3.fromRGB(120,65,200); tabAllBtn.AutoButtonColor=false
    tabAllBtn.BorderSizePixel=0; tabAllBtn.ZIndex=6
    Instance.new("UICorner",tabAllBtn).CornerRadius=UDim.new(0,8)

    local function makeScroll(parent, visible)
        local s = Instance.new("ScrollingFrame", parent)
        s.Size  = UDim2.new(1,-24,0,scrollH); s.Position=UDim2.new(0,12,0,scrollTop)
        s.BackgroundColor3=Color3.fromRGB(12,6,26); s.BorderSizePixel=0
        s.ScrollBarThickness=6; s.ScrollBarImageColor3=Color3.fromRGB(140,60,255)
        s.CanvasSize=UDim2.new(0,0,0,0); s.AutomaticCanvasSize=Enum.AutomaticSize.Y
        s.ClipsDescendants=true; s.Visible=visible
        Instance.new("UICorner",s).CornerRadius=UDim.new(0,10)
        local layout=Instance.new("UIListLayout",s)
        layout.Padding=UDim.new(0,4); layout.SortOrder=Enum.SortOrder.LayoutOrder
        local pad=Instance.new("UIPadding",s)
        pad.PaddingTop=UDim.new(0,4); pad.PaddingLeft=UDim.new(0,4); pad.PaddingRight=UDim.new(0,4)
        return s
    end

    local priorityScroll = makeScroll(inner, true)
    local leftScroll     = makeScroll(inner, false)

    local closeBtn = Instance.new("TextButton", inner)
    closeBtn.Size  = UDim2.new(1,-24,0,34); closeBtn.Position=UDim2.new(0,12,1,-46)
    closeBtn.BackgroundColor3=Color3.fromRGB(50,18,110); closeBtn.Text="CLOSE"
    closeBtn.Font=Enum.Font.GothamBold; closeBtn.TextSize=13
    closeBtn.TextColor3=Color3.fromRGB(220,180,255); closeBtn.BorderSizePixel=0
    closeBtn.AutoButtonColor=false; closeBtn.ZIndex=6
    Instance.new("UICorner",closeBtn).CornerRadius=UDim.new(0,8)
    closeBtn.MouseButton1Click:Connect(function() _priorityGui:Destroy(); _priorityGui=nil end)

    local function savePriority() PRIORITY_LIST=priorityList end
    local refreshAllList, refreshPriorityList

    local function removeFromPriority(name)
        for i=#priorityList,1,-1 do if priorityList[i]==name then table.remove(priorityList,i) end end
        prioritySet[name]=nil; savePriority(); refreshPriorityList(); refreshAllList()
    end
    local function addToPriority(name)
        if prioritySet[name] then return end
        table.insert(priorityList,name); prioritySet[name]=true; savePriority()
        refreshPriorityList(); refreshAllList()
    end

    local function makeVpIcon(parent, name, posX)
        local iconSz = 40
        local vp = getBrainrotViewportClone(name)
        if vp then
            vp.Name="BrainrotIcon"; vp.BackgroundTransparency=0.6
            vp.BackgroundColor3=Color3.fromRGB(20,10,40)
            Instance.new("UICorner",vp).CornerRadius=UDim.new(0,6)
            vp.AnchorPoint=Vector2.new(0,0.5); vp.Position=UDim2.new(0,posX,0.5,0)
            vp.Size=UDim2.new(0,iconSz,0,iconSz); vp.Parent=parent
        end
        return vp and iconSz or 0
    end

    refreshAllList = function()
        for _,c in ipairs(leftScroll:GetChildren()) do
            if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then c:Destroy() end
        end
        for _,name in ipairs(allNames) do
            local row = Instance.new("Frame", leftScroll)
            row.Size  = UDim2.new(1,-8,0,48); row.BackgroundColor3=Color3.fromRGB(16,9,32)
            row.BorderSizePixel=0
            Instance.new("UICorner",row).CornerRadius=UDim.new(0,8)
            Instance.new("UIStroke",row).Color=Color3.fromRGB(50,20,100)
            local iconW  = makeVpIcon(row, name, 4)
            local lblOff = iconW>0 and iconW+12 or 12
            local lbl    = Instance.new("TextLabel", row)
            lbl.Size  = UDim2.new(1,-(lblOff+48),1,0); lbl.Position=UDim2.new(0,lblOff,0,0)
            lbl.BackgroundTransparency=1; lbl.Text=name; lbl.Font=Enum.Font.GothamBold; lbl.TextSize=12
            lbl.TextXAlignment=Enum.TextXAlignment.Left; lbl.TextTruncate=Enum.TextTruncate.AtEnd
            lbl.TextColor3=prioritySet[name] and Color3.fromRGB(100,50,160) or Color3.fromRGB(220,180,255)
            local btn = Instance.new("TextButton", row)
            btn.Size  = UDim2.new(0,34,0,34); btn.Position=UDim2.new(1,-38,0,7)
            btn.BackgroundColor3=Color3.fromRGB(50,18,110)
            btn.Text  = prioritySet[name] and "-" or "+"
            btn.Font  = Enum.Font.GothamBlack; btn.TextSize=16
            btn.TextColor3=prioritySet[name] and Color3.fromRGB(255,80,80) or Color3.fromRGB(140,255,180)
            btn.BorderSizePixel=0; btn.AutoButtonColor=false
            Instance.new("UICorner",btn).CornerRadius=UDim.new(0,6)
            btn.MouseButton1Click:Connect(function()
                if prioritySet[name] then removeFromPriority(name)
                else addToPriority(name) end
            end)
        end
    end

    refreshPriorityList = function()
        for _,c in ipairs(priorityScroll:GetChildren()) do
            if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then c:Destroy() end
        end
        for i,name in ipairs(priorityList) do
            local row = Instance.new("Frame", priorityScroll)
            row.Size  = UDim2.new(1,-8,0,48); row.BackgroundColor3=Color3.fromRGB(16,9,32)
            row.BorderSizePixel=0; row.LayoutOrder=i
            Instance.new("UICorner",row).CornerRadius=UDim.new(0,8)
            Instance.new("UIStroke",row).Color=Color3.fromRGB(50,20,100)
            local idxLbl = Instance.new("TextLabel", row)
            idxLbl.Size  = UDim2.new(0,20,1,0); idxLbl.Position=UDim2.new(0,4,0,0)
            idxLbl.BackgroundTransparency=1; idxLbl.Text=tostring(i)
            idxLbl.Font=Enum.Font.GothamBold; idxLbl.TextSize=11
            idxLbl.TextColor3=Color3.fromRGB(100,50,160)
            local iconW  = makeVpIcon(row, name, 24)
            local lblOff = iconW>0 and (24+iconW+4) or 24
            local lbl    = Instance.new("TextLabel", row)
            lbl.Size  = UDim2.new(1,-(lblOff+110),1,0); lbl.Position=UDim2.new(0,lblOff,0,0)
            lbl.BackgroundTransparency=1; lbl.Text=name; lbl.Font=Enum.Font.GothamBold; lbl.TextSize=12
            lbl.TextXAlignment=Enum.TextXAlignment.Left; lbl.TextTruncate=Enum.TextTruncate.AtEnd
            lbl.TextColor3=Color3.fromRGB(220,180,255)
            local function makeSmallBtn(txt, xOff, col, cb)
                local b = Instance.new("TextButton", row)
                b.Size  = UDim2.new(0,28,0,34); b.Position=UDim2.new(1,xOff,0,7)
                b.BackgroundColor3=Color3.fromRGB(50,18,110); b.Text=txt
                b.Font=Enum.Font.GothamBlack; b.TextSize=12; b.TextColor3=col
                b.BorderSizePixel=0; b.AutoButtonColor=false
                Instance.new("UICorner",b).CornerRadius=UDim.new(0,6)
                b.MouseButton1Click:Connect(cb)
            end
            makeSmallBtn("↑",-104,Color3.fromRGB(180,130,255),function()
                if i<=1 then return end
                priorityList[i],priorityList[i-1]=priorityList[i-1],priorityList[i]
                savePriority(); refreshPriorityList()
            end)
            makeSmallBtn("↓",-72,Color3.fromRGB(180,130,255),function()
                if i>=#priorityList then return end
                priorityList[i],priorityList[i+1]=priorityList[i+1],priorityList[i]
                savePriority(); refreshPriorityList()
            end)
            makeSmallBtn("X",-40,Color3.fromRGB(255,80,80),function()
                removeFromPriority(name)
            end)
        end
    end

    tabPrioBtn.MouseButton1Click:Connect(function()
        tabPrioBtn.BackgroundColor3=Color3.fromRGB(50,18,110); tabPrioBtn.TextColor3=Color3.fromRGB(220,180,255)
        tabAllBtn.BackgroundColor3=Color3.fromRGB(16,9,32);    tabAllBtn.TextColor3=Color3.fromRGB(120,65,200)
        priorityScroll.Visible=true; leftScroll.Visible=false
    end)
    tabAllBtn.MouseButton1Click:Connect(function()
        tabAllBtn.BackgroundColor3=Color3.fromRGB(50,18,110); tabAllBtn.TextColor3=Color3.fromRGB(220,180,255)
        tabPrioBtn.BackgroundColor3=Color3.fromRGB(16,9,32);  tabPrioBtn.TextColor3=Color3.fromRGB(120,65,200)
        leftScroll.Visible=true; priorityScroll.Visible=false
    end)

    refreshPriorityList(); refreshAllList()
end

