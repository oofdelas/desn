-- Detecção do lado mais próximo da BASE DO ALVO
local function tweenGetClosestSideOfTargetBase(hrpPos, targetPartPos, plotObj)
    local plotRootPart = plotObj and (plotObj:FindFirstChild("MainRootPart") or plotObj:FindFirstChildWhichIsA("BasePart"))
    local plotCenter   = plotRootPart and plotRootPart.Position or targetPartPos

    local slotPositions = {}
    local podiums = plotObj and plotObj:FindFirstChild("AnimalPodiums")
    if podiums then
        for _, pod in ipairs(podiums:GetChildren()) do
            local base  = pod:FindFirstChild("Base")
            local spawn = base and (base:FindFirstChild("Spawn") or base:FindFirstChildWhichIsA("BasePart"))
                or pod:FindFirstChildWhichIsA("BasePart")
            if spawn and spawn.Position.Y <= 10 then
                table.insert(slotPositions, spawn.Position)
            end
        end
    end

    local isSecondFloor = targetPartPos.Y > 11.5
    local slotCenterX   = plotCenter.X
    local slotCenterZ   = plotCenter.Z
    local slotMinZ      = plotCenter.Z - 18
    local slotMaxZ      = plotCenter.Z + 18
    local slotMinX      = plotCenter.X
    local slotMaxX      = plotCenter.X
    local slotFloorY    = isSecondFloor and 11.8 or -6.2

    if #slotPositions > 0 then
        local sumX = 0
        local minZ, maxZ = math.huge, -math.huge
        local minX, maxX = math.huge, -math.huge
        local sumY, count = 0, 0
        for _, p in ipairs(slotPositions) do
            sumX += p.X
            if p.Z < minZ then minZ = p.Z end
            if p.Z > maxZ then maxZ = p.Z end
            if p.X < minX then minX = p.X end
            if p.X > maxX then maxX = p.X end
            sumY  += p.Y
            count += 1
        end
        slotCenterX = sumX / #slotPositions
        slotMinZ    = minZ; slotMaxZ = maxZ
        slotMinX    = minX; slotMaxX = maxX
        slotCenterZ = (minZ + maxZ) / 2
        if not isSecondFloor and count > 0 then
            slotFloorY = sumY / count
        end
    end

    -- Dois lados possíveis fora da base (norte e sul)
    local OUTSIDE_OFFSET = 8
    local zNorth = slotMaxZ + OUTSIDE_OFFSET
    local zSouth = slotMinZ - OUTSIDE_OFFSET

    -- Escolhe o lado mais próximo do PLAYER (não da base dele, mas da posição atual dele)
    local zPrimary, zFallback
    if math.abs(hrpPos.Z - zNorth) <= math.abs(hrpPos.Z - zSouth) then
        zPrimary  = zNorth
        zFallback = zSouth
    else
        zPrimary  = zSouth
        zFallback = zNorth
    end

    -- X: entra pelo canto mais próximo do player
    local cornerX = (math.abs(hrpPos.X - slotMinX) <= math.abs(hrpPos.X - slotMaxX))
        and slotMinX or slotMaxX

    local function sideIsClear(testZ)
        local rayOrigin = Vector3.new(cornerX, slotFloorY + 10, testZ)
        local rayDir    = Vector3.new(0, -15, 0)
        local rayParams = RaycastParams.new()
        rayParams.FilterType = Enum.RaycastFilterType.Exclude
        rayParams.FilterDescendantsInstances = {LocalPlayer.Character}
        local result = Workspace:Raycast(rayOrigin, rayDir, rayParams)
        if result then return result.Position.Y < (slotFloorY + 3) end
        return true
    end

    local chosenZ = sideIsClear(zPrimary) and zPrimary or zFallback

    local sideY    = slotFloorY + 3.5
    local sideSpot = Vector3.new(cornerX, sideY, chosenZ)

    local inwardPrimaryZ = math.abs(chosenZ - slotCenterZ) >= math.abs(cornerX - slotCenterX)

    local function lookInward(pos)
        local y = pos.Y
        if inwardPrimaryZ then
            local t = Vector3.new(pos.X, y, slotCenterZ)
            if (t - pos).Magnitude > 0.05 then return CFrame.lookAt(pos, t) end
            t = Vector3.new(slotCenterX, y, pos.Z)
            if (t - pos).Magnitude > 0.05 then return CFrame.lookAt(pos, t) end
        else
            local t = Vector3.new(slotCenterX, y, pos.Z)
            if (t - pos).Magnitude > 0.05 then return CFrame.lookAt(pos, t) end
            t = Vector3.new(pos.X, y, slotCenterZ)
            if (t - pos).Magnitude > 0.05 then return CFrame.lookAt(pos, t) end
        end
        return CFrame.lookAt(pos, pos + Vector3.new(0, 0, chosenZ >= slotCenterZ and -1 or 1))
    end

    local approachRot = _G._tpPlannedRot or (lookInward(sideSpot) - sideSpot)
    if not _G._tpPlannedRot then _G._tpPlannedRot = approachRot end

    return sideSpot, approachRot, isSecondFloor
end

local function tweenGoToBrainrot(hum, hrp, targetPart, rotBeforeEntering)
    if not targetPart or not targetPart.Parent then return end

    local char = hrp.Parent
    tweenEquipCarpet(hum, char)

    local verticalDiff = targetPart.Position.Y - hrp.Position.Y

    if verticalDiff > 2 then
        local airPos = Vector3.new(
            targetPart.Position.X,
            targetPart.Position.Y - 8,
            targetPart.Position.Z
        )
        local plat = Instance.new("Part")
        plat.Name         = "TweenStealPlat"
        plat.Size         = Vector3.new(3, 1, 3)
        plat.Position     = airPos - Vector3.new(0, 5, 0)
        plat.Color        = Color3.new(1, 0, 0)
        plat.Material     = Enum.Material.Neon
        plat.Anchored     = true
        plat.CanCollide   = true
        plat.Transparency = 0.3
        plat.Parent       = Workspace

        RunService.Heartbeat:Wait()

        tweenFlySmooth(hrp, hum, airPos, 80, 15)

        for i = 1, 10 do
            if LocalPlayer:GetAttribute("Stealing") then break end
            hrp.AssemblyLinearVelocity = Vector3.new(
                hrp.AssemblyLinearVelocity.X, 0, hrp.AssemblyLinearVelocity.Z
            )
            hrp.CFrame = CFrame.new(airPos) * rotBeforeEntering
            task.wait(0.05)
        end

        task.spawn(function()
            local start = tick()
            while tick() - start < 20 do
                if LocalPlayer:GetAttribute("Stealing") then break end
                task.wait(0.1)
            end
            if plat and plat.Parent then plat:Destroy() end
        end)
    else
        tweenFlySmooth(hrp, hum, targetPart.Position, 80, 15)

        for i = 1, 10 do
            if LocalPlayer:GetAttribute("Stealing") then break end
            hrp.AssemblyLinearVelocity = Vector3.new(
                hrp.AssemblyLinearVelocity.X, 0, hrp.AssemblyLinearVelocity.Z
            )
            if (hrp.Position - targetPart.Position).Magnitude > 3 then
                hrp.CFrame = CFrame.new(targetPart.Position) * rotBeforeEntering
            end
            task.wait(0.05)
        end
    end

    tweenZeroVel(hrp)
end

local function runCloneTP(targetPetData)
    if State.isTpMoving then return end
    State.isTpMoving = true

    local RunService        = game:GetService("RunService")
    local ReplicatedStorage = game:GetService("ReplicatedStorage")

    local char = LocalPlayer.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    local hum  = char and char:FindFirstChild("Humanoid")

    if not hrp or not hum or hum.Health <= 0 then
        State.isTpMoving = false
        return
    end

    local function finish()
        State.isTpMoving = false
    end

    -- ══════════════════════════════════════════
    -- CARREGAR MÓDULOS
    -- ══════════════════════════════════════════
    local AnimalsShared, AnimalsData, SynchronizerModule

    local modOk = pcall(function()
        local Packages     = ReplicatedStorage:WaitForChild("Packages",  5)
        local SharedFolder = ReplicatedStorage:WaitForChild("Shared",    5)
        local DataFolder   = ReplicatedStorage:WaitForChild("Datas",     5)
        AnimalsShared      = require(SharedFolder.Animals)
        AnimalsData        = require(DataFolder.Animals)
        SynchronizerModule = require(Packages.Synchronizer)
    end)

    if not modOk then
        warn("[CloneTP] Falha ao carregar módulos")
        finish()
        return
    end

    local function getChannel(name)
        local all = SynchronizerModule:GetAllChannels()
        if all[name] then return all[name] end
        return SynchronizerModule:Create(nil, name, nil)
    end

    local function fireConnections(event, ...)
        local ok, connections = pcall(getconnections, event)
        if not ok or not connections then return end
        local args = {...}
        for _, conn in ipairs(connections) do
            if conn and conn.Function then
                task.spawn(conn.Function, table.unpack(args))
            end
        end
    end

    local function preparePrompt(prompt)
        prompt.Enabled              = true
        prompt.MaxActivationDistance = 1e10
        prompt.RequiresLineOfSight  = false
        prompt.UIOffset             = Vector2.new(0, 0)
    end

    -- ══════════════════════════════════════════
    -- ACHAR ALVO (PRIORITY MODE + NORMAL)
    -- ══════════════════════════════════════════
    local Plots = workspace:FindFirstChild("Plots")
    if not Plots then finish() return end

    local targetPart, targetPrompt, targetPos
    local targetEntry, targetPlot

    if targetPetData and targetPetData.plot then
        targetPart = findAdorneeGlobal(targetPetData)
        targetPlot = Plots:FindFirstChild(targetPetData.plot)

        if targetPart and targetPlot then
            targetPos = targetPart.Position + Vector3.new(0, 2, 0)

            for _, desc in ipairs(targetPlot:GetDescendants()) do
                if desc:IsA("ProximityPrompt") then
                    local parent = desc.Parent
                    if parent and parent:IsA("BasePart") then
                        if (parent.Position - targetPart.Position).Magnitude < 15 then
                            targetPrompt = desc
                            break
                        end
                    elseif parent then
                        local bp = parent:FindFirstChildWhichIsA("BasePart")
                        if bp and (bp.Position - targetPart.Position).Magnitude < 15 then
                            targetPrompt = desc
                            break
                        end
                    end
                end
            end
        end
    end

    if not targetPos or not targetPrompt then
        local bestGen = -math.huge
        for _, plot in ipairs(Plots:GetChildren()) do
            if not plot:IsA("Model") or not plot:GetAttribute("Tier") then continue end
            local ch = getChannel(plot.Name)
            if not ch then continue end
            for _, entry in pairs(ch:Get("AnimalList") or {}) do
                if type(entry) == "table" and entry.Index then
                    local ok2, gen = pcall(function()
                        return AnimalsShared:GetGeneration(entry.Index, entry.Mutation, entry.Traits, nil)
                    end)
                    local genVal = (ok2 and type(gen) == "number") and gen or 0
                    if genVal > bestGen then
                        bestGen     = genVal
                        targetEntry = entry
                        targetPlot  = plot
                    end
                end
            end
        end

        if targetEntry and targetPlot then
            local data        = AnimalsData[targetEntry.Index]
            local displayName = (data and data.DisplayName) or targetEntry.Index

            for _, desc in ipairs(targetPlot:GetDescendants()) do
                if desc:IsA("ProximityPrompt") and desc.ObjectText == displayName then
                    targetPrompt = desc
                    break
                end
            end

            local petModel = targetPlot:FindFirstChild(targetEntry.Index)
            local petPart  = petModel and (petModel.PrimaryPart or petModel:FindFirstChildWhichIsA("BasePart"))
            if not petPart and targetPrompt then
                local pp = targetPrompt.Parent
                if pp and pp:IsA("BasePart") then petPart = pp
                elseif pp then petPart = pp:FindFirstChildWhichIsA("BasePart") end
            end
            if petPart then targetPos = petPart.Position + Vector3.new(0, 2, 0) end
        end
    end

    if not targetPos or not targetPrompt then
        warn("[CloneTP] Alvo ou prompt não encontrado")
        finish()
        return
    end

    print("[CloneTP] Prompt:", targetPrompt:GetFullName())
    preparePrompt(targetPrompt)

    -- ══════════════════════════════════════════
    -- FERRAMENTAS
    -- ══════════════════════════════════════════
    local quantum = LocalPlayer.Backpack:FindFirstChild("Quantum Cloner") or char:FindFirstChild("Quantum Cloner")
    local bat     = LocalPlayer.Backpack:FindFirstChild("Bat") or char:FindFirstChild("Bat")
    if not quantum or not bat then finish() return end

    -- ══════════════════════════════════════════
    -- SPAWNAR CLONE
    -- ══════════════════════════════════════════
    local cloneName    = tostring(LocalPlayer.UserId) .. "_Clone"
    local spawnedClone = workspace:FindFirstChild(cloneName)

    if not spawnedClone then
        local cloneBindable = Instance.new("BindableEvent")
        local cloneConn = workspace.ChildAdded:Connect(function(child)
            if child.Name == cloneName then
                spawnedClone = child
                pcall(function() cloneBindable:Fire() end)
            end
        end)

        local spamStart = tick()
        local spamConn
        spamConn = RunService.Heartbeat:Connect(function()
            if spawnedClone or tick() - spamStart >= 3.05 then
                spamConn:Disconnect()
                return
            end
            pcall(function()
                quantum.Parent = char
                quantum:Activate()
                quantum.Parent = LocalPlayer.Backpack
                for _ = 1, 14 do
                    bat.Parent = char
                    bat.Parent = LocalPlayer.Backpack
                end
            end)
        end)

        local timeout = task.delay(4, function()
            pcall(function() cloneBindable:Fire() end)
        end)

        cloneBindable.Event:Wait()
        task.cancel(timeout)
        cloneConn:Disconnect()
        cloneBindable:Destroy()
    end

    if not spawnedClone then finish() return end

    -- ══════════════════════════════════════════
    -- PREPARAR CLONE
    -- ══════════════════════════════════════════
    task.wait(0.3)
    local cloneHrp = spawnedClone:WaitForChild("HumanoidRootPart", 10)
    if not cloneHrp then finish() return end

    bat.Parent = char
    bat.Parent = spawnedClone
    bat.Parent = LocalPlayer.Backpack
    bat.Parent = spawnedClone
    task.wait(0.05)

    local cloneHum = spawnedClone:FindFirstChildOfClass("Humanoid")
    if cloneHum then
        task.spawn(function()
            pcall(function() cloneHum:ChangeState(Enum.HumanoidStateType.Dead) end)
        end)
    end

    pcall(function()
        setsimulationradius(1e9, 1e9)
        sethiddenproperty(LocalPlayer, "SimulationRadius",    1e9)
        sethiddenproperty(LocalPlayer, "MaxSimulationRadius", 1e9)
    end)

    -- ══════════════════════════════════════════
    -- MOVER CLONE + DISPARAR PROMPT
    -- ══════════════════════════════════════════
    local loopStart    = tick()
    local loopDuration = 0.5

    local loopConn
    loopConn = RunService.Heartbeat:Connect(function()
        if not spawnedClone.Parent or not cloneHrp.Parent then
            loopConn:Disconnect()
            return
        end
        if tick() - loopStart > loopDuration then
            loopConn:Disconnect()
            return
        end
        pcall(function()
            cloneHrp.CFrame                  = CFrame.new(targetPos)
            cloneHrp.AssemblyLinearVelocity  = Vector3.zero
            cloneHrp.AssemblyAngularVelocity = Vector3.zero
        end)
        fireConnections(targetPrompt.Triggered, LocalPlayer)
    end)

    task.wait(loopDuration + 0.1)

    -- ══════════════════════════════════════════
    -- TROCAR COM O CLONE
    -- ══════════════════════════════════════════
    pcall(function() hum:EquipTool(quantum) end)

    local equipStart = tick()
    while quantum.Parent ~= char and tick() - equipStart < 0.3 do
        RunService.Heartbeat:Wait()
    end

    local toolsFrames = LocalPlayer.PlayerGui:FindFirstChild("ToolsFrames")
    local qcFrame     = toolsFrames and toolsFrames:FindFirstChild("QuantumCloner")
    local tpButton    = qcFrame and qcFrame:FindFirstChild("TeleportToClone")

    if tpButton then
        tpButton.Visible = true
        RunService.Heartbeat:Wait()
        firesignal(tpButton.MouseButton1Up)
    end

    task.wait(0.2)
    finish()
end

local function runAutoSnipeV2(targetPetData)
    if State.isTpMoving then return end
    State.isTpMoving = true

    local char = LocalPlayer.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    local hum  = char and char:FindFirstChild("Humanoid")
    if not hrp or not hum or hum.Health <= 0 then
        State.isTpMoving = false
        return
    end

    local savedAutoRotate = hum.AutoRotate
    pcall(function() hum.AutoRotate = false end)
    _G._tpPlannedRot = nil

    local ragdollConn = nil
    local holdConn = nil

    local function finish()
        if ragdollConn then
            ragdollConn:Disconnect()
            ragdollConn = nil
        end

        if holdConn then
            holdConn:Disconnect()
            holdConn = nil
        end

        pcall(function()
            if hrp then
                hrp.AssemblyLinearVelocity = Vector3.zero
                hrp.AssemblyAngularVelocity = Vector3.zero
            end
        end)

        pcall(function()
            if hum and hum.Health > 0 then
                hum:ChangeState(Enum.HumanoidStateType.GettingUp)
            end
        end)

        pcall(function() hum.AutoRotate = savedAutoRotate end)
        State.isTpMoving = false
    end

    local targetPart = findAdorneeGlobal(targetPetData)
    if not targetPart then
        finish()
        return
    end

    local plotsFolder = Workspace:FindFirstChild("Plots")
    local plotObj = plotsFolder and plotsFolder:FindFirstChild(targetPetData.plot)

    local function getPlotRootPart(plot)
        if not plot then return nil end
        return plot:FindFirstChild("MainRootPart")
            or plot:FindFirstChildWhichIsA("BasePart")
    end

    local function getMapSide(pos)
        if not pos then return nil end
        return (pos.X < -400) and "left" or "right"
    end

    local function findMyPlotPos()
        if not plotsFolder then return nil, nil end

        for _, plot in ipairs(plotsFolder:GetChildren()) do
            local sign = plot:FindFirstChild("PlotSign")
            if sign then
                local sg = sign:FindFirstChildWhichIsA("SurfaceGui", true)
                if sg then
                    local label = sg:FindFirstChildWhichIsA("TextLabel", true)
                    if label then
                        local text = label.Text:lower()
                        if text:find(LocalPlayer.DisplayName:lower(), 1, true)
                            or text:find(LocalPlayer.Name:lower(), 1, true) then
                            local root = getPlotRootPart(plot)
                            return plot.Name, root and root.Position or nil
                        end
                    end
                end
            end
        end

        return nil, nil
    end

    local function getColumnZExtremes(sideName)
        if not plotsFolder or not sideName then return nil, nil end

        local minZ, maxZ = math.huge, -math.huge
        for _, plot in ipairs(plotsFolder:GetChildren()) do
            local root = getPlotRootPart(plot)
            if root and getMapSide(root.Position) == sideName then
                if root.Position.Z < minZ then minZ = root.Position.Z end
                if root.Position.Z > maxZ then maxZ = root.Position.Z end
            end
        end

        if minZ == math.huge then return nil, nil end
        return minZ, maxZ
    end

    local targetPlotRoot = getPlotRootPart(plotObj)
    local targetPlotPos = targetPlotRoot and targetPlotRoot.Position or targetPart.Position

    local myPlotName, myPlotPos = findMyPlotPos()
    local mySide = getMapSide(myPlotPos)
    local targetSide = getMapSide(targetPlotPos)

    local isFrontBase = false
    local isSideBase = false

    if myPlotPos and myPlotName ~= targetPetData.plot then
        local sameLaneZ = math.abs(myPlotPos.Z - targetPlotPos.Z) < 50

        if mySide ~= targetSide and sameLaneZ then
            isFrontBase = true

        elseif mySide == targetSide then
            local minZ = math.min(myPlotPos.Z, targetPlotPos.Z)
            local maxZ = math.max(myPlotPos.Z, targetPlotPos.Z)
            local basesBetween = 0

            for _, plot in ipairs(plotsFolder:GetChildren()) do
                local root = getPlotRootPart(plot)
                if root and getMapSide(root.Position) == mySide then
                    local pZ = root.Position.Z
                    if pZ > (minZ + 10) and pZ < (maxZ - 10) then
                        basesBetween = basesBetween + 1
                    end
                end
            end

            if basesBetween == 0 then
                isSideBase = true
            end
        end
    end

    local function getForcedSideByZ(zDir)
        local fakeFrom = Vector3.new(
            targetPlotPos.X,
            hrp.Position.Y,
            targetPlotPos.Z + (120 * zDir)
        )
        return tweenGetClosestSideOfTargetBase(fakeFrom, targetPart.Position, plotObj)
    end

    local forcedZDir = nil

    -- ============================================================
    -- BASE DE CANTO: força lado oposto da barreira
    -- ============================================================
    do
        local minZ, maxZ = getColumnZExtremes(targetSide)
        local cornerTol = 25

        if minZ and math.abs(targetPlotPos.Z - minZ) <= cornerTol then
            forcedZDir = 1
        elseif maxZ and math.abs(targetPlotPos.Z - maxZ) <= cornerTol then
            forcedZDir = -1
        end
    end

    -- ============================================================
    -- BASE NA FRENTE: escolhe um lado e TERMINA no mesmo lado
    -- ============================================================
    if not forcedZDir and isFrontBase then
        forcedZDir = (hrp.Position.Z < targetPlotPos.Z) and -1 or 1
    end

    local sideSpot, approachRot, isSecondFloor

    if forcedZDir then
        sideSpot, approachRot, isSecondFloor = getForcedSideByZ(forcedZDir)
    end

    if not sideSpot then
        sideSpot, approachRot, isSecondFloor = tweenGetClosestSideOfTargetBase(
            hrp.Position,
            targetPart.Position,
            plotObj
        )
    end

    if not sideSpot or not approachRot then
        finish()
        return
    end

    -- ============================================================
    -- EQUIPA O TAPETE + PHYSICS (RAGDOLL TEST)
    -- ============================================================
    local carpet = LocalPlayer.Backpack:FindFirstChild(Config.Tool) or char:FindFirstChild(Config.Tool)
    if carpet then
        pcall(function()
            hum:EquipTool(carpet)
        end)

        task.wait(0.03)

        pcall(function()
            hum:ChangeState(Enum.HumanoidStateType.Physics)
        end)

        ragdollConn = RunService.Heartbeat:Connect(function()
            if hum and hum.Parent and hum.Health > 0 then
                if hum:GetState() ~= Enum.HumanoidStateType.Physics then
                    pcall(function()
                        hum:ChangeState(Enum.HumanoidStateType.Physics)
                    end)
                end
            end
        end)
    end

    hrp.CFrame = CFrame.new(hrp.Position) * approachRot
    task.wait(0.01)

    -- ============================================================
    -- MOVIMENTO ATÉ O sideSpot
    -- ============================================================
    if isSideBase then
        tweenFlyTo(hrp, sideSpot, 8)
    else
        local targetHeight = sideSpot.Y + 10
        local jumpStart = tick()

        while hrp.Position.Y < targetHeight and (tick() - jumpStart) < 1.5 do
            hrp.AssemblyLinearVelocity = Vector3.new(
                hrp.AssemblyLinearVelocity.X,
                80,
                hrp.AssemblyLinearVelocity.Z
            )
            RunService.Heartbeat:Wait()
        end

        if isFrontBase then
            local detourX = myPlotPos and ((myPlotPos.X + sideSpot.X) / 2) or ((hrp.Position.X + sideSpot.X) / 2)
            local detourY = sideSpot.Y + 8
            local detourZ = sideSpot.Z
            local detourPos = Vector3.new(detourX, detourY, detourZ)

            tweenFlyTo(hrp, detourPos, 8)
            tweenFlyTo(hrp, sideSpot, 8)
        else
            local midX
            if sideSpot.X < -400 then
                midX = sideSpot.X + 25
            else
                midX = sideSpot.X - 25
            end

            local midZ = sideSpot.Z + (hrp.Position.Z - sideSpot.Z) * 0.40
            local midY = math.max(sideSpot.Y + 6, 20)
            local midPos = Vector3.new(midX, midY, midZ)

            tweenFlyTo(hrp, midPos, 8)
            tweenFlyTo(hrp, sideSpot, 8)
        end
    end

    -- ============================================================
    -- ESTABILIZA NO sideSpot + SAI DO PHYSICS
    -- ============================================================
    tweenZeroVel(hrp)
    hrp.CFrame = CFrame.new(sideSpot) * approachRot
    pcall(function()
        hrp.AssemblyLinearVelocity = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
    end)

    if ragdollConn then
        ragdollConn:Disconnect()
        ragdollConn = nil
    end

    pcall(function()
        hum:ChangeState(Enum.HumanoidStateType.GettingUp)
    end)

    task.wait(0.08)

    -- ============================================================
    -- HOLD Y NO 2 ANDAR
    -- ============================================================
    if isSecondFloor then
        holdConn = RunService.Heartbeat:Connect(function()
            if hrp and hrp.Parent then
                hrp.AssemblyLinearVelocity = Vector3.new(
                    hrp.AssemblyLinearVelocity.X, 0, hrp.AssemblyLinearVelocity.Z
                )
                if math.abs(hrp.Position.Y - sideSpot.Y) > 1 then
                    local keepRot = hrp.CFrame - hrp.Position
                    hrp.CFrame = CFrame.new(hrp.Position.X, sideSpot.Y, hrp.Position.Z) * keepRot
                end
            end
        end)
    end

    -- ============================================================
    -- WALL SNAP
    -- ============================================================
    tweenApproachWall(char, hrp, hum)
    local wallReady = tweenFlyToWallAndConfirm(hum, hrp, char)

    if holdConn then
        holdConn:Disconnect()
        holdConn = nil
    end

    pcall(function()
        hrp.AssemblyLinearVelocity = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
    end)

    -- ============================================================
    -- CLONE
    -- ============================================================
    if wallReady then
        tweenDoClone(hrp, hum)
        while _G.isCloning do
            task.wait()
        end
    end

    -- ============================================================
    -- VAI AO BRAINROT
    -- ============================================================
    local char2 = LocalPlayer.Character
    local hum2  = char2 and char2:FindFirstChildOfClass("Humanoid")
    local hrp2  = char2 and char2:FindFirstChild("HumanoidRootPart")

    if char2 and hum2 and hrp2 and hum2.Health > 0 then
        tweenEquipCarpet(hum2, char2)
        tweenGoToBrainrot(hum2, hrp2, targetPart, _G._tpPlannedRot or approachRot)
    end

    finish()
end

