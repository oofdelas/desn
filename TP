                Vector3.new(-342,-4,-100),Vector3.new(-342,-4,6),
                Vector3.new(-342,-4,114),Vector3.new(-342,-4,220)
            }
            local FACE_TARGETS = {
                Vector3.new(-519,-3,221),Vector3.new(-519,-3,114),
