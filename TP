    else
        local baseOpen = _G._isTargetPlotUnlocked(targetPetData.plot)
        if baseOpen then
            local CLONE_POSITIONS_FLOOR = {
                Vector3.new(-476,-4,221),Vector3.new(-476,-4,114),
