local function findNearestWallHit(maxDist)
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local origin = hrp.Position + Vector3.new(0, 2, 0)
    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    rayParams.FilterDescendantsInstances = {char}
    local dirs = {
        Vector3.new(1,0,0), Vector3.new(-1,0,0),
        Vector3.new(0,0,1), Vector3.new(0,0,-1),
        Vector3.new(1,0,1).Unit, Vector3.new(1,0,-1).Unit,
        Vector3.new(-1,0,1).Unit, Vector3.new(-1,0,-1).Unit,
    }
    local best, bestDist = nil, (maxDist or 60) + 1
    for i=1,#dirs do
        local dir = dirs[i]
        local result = Workspace:Raycast(origin, dir*(maxDist or 60), rayParams)
        if result and result.Instance and result.Instance:IsA("BasePart") then
            local d = (result.Position - origin).Magnitude
            if d < bestDist then
                bestDist = d
                best = {result=result, dir=dir, origin=origin, hrp=hrp}
            end
        end
    end
    return best
end

local function computeWallSnapCFrame(hitData, extraGap)
    if not hitData or not hitData.result or not hitData.hrp then return nil end
    local hrp = hitData.hrp
    local res = hitData.result
    local normal = res.Normal
    local nXZ = Vector3.new(normal.X, 0, normal.Z)
    if nXZ.Magnitude < 0.001 then
        nXZ = Vector3.new(hitData.dir.X, 0, hitData.dir.Z).Unit
    else
        nXZ = nXZ.Unit
    end
    local halfExtent = (math.abs(nXZ.X)*hrp.Size.X + math.abs(nXZ.Z)*hrp.Size.Z)*0.5
    local gap = extraGap or 0.05
    local snapPos = Vector3.new(res.Position.X, hrp.Position.Y, res.Position.Z) + (nXZ*(halfExtent+gap))
    local lookAt = snapPos - nXZ
    return CFrame.lookAt(snapPos, lookAt)
end

_G.snapToWall = function(gap)
    local hitData = findNearestWallHit(80)
    local cf = computeWallSnapCFrame(hitData, gap or 0.05)
    if cf and hitData and hitData.hrp and hitData.hrp.Parent then
        _G._tpPlannedRot = cf - cf.Position
        hitData.hrp.CFrame = cf
    end
    return hitData and hitData.result
end

_G._isTargetPlotUnlocked = function(plotName)
    local ok, res = pcall(function()
        local plots = Workspace:FindFirstChild("Plots")
        if not plots then return false end
        local targetPlot = plots:FindFirstChild(plotName)
        if not targetPlot then return false end
        local unlockFolder = targetPlot:FindFirstChild("Unlock")
        if not unlockFolder then return true end
        local unlockItems = {}
        for _, item in pairs(unlockFolder:GetChildren()) do
            local pos = nil
            if item:IsA("Model") then pcall(function() pos=item:GetPivot().Position end)
            elseif item:IsA("BasePart") then pos = item.Position end
            if pos then table.insert(unlockItems,{Object=item,Height=pos.Y}) end
        end
        table.sort(unlockItems,function(a,b) return a.Height<b.Height end)
        if #unlockItems==0 then return true end
        local floor1Door = unlockItems[1].Object
        for _,desc in ipairs(floor1Door:GetDescendants()) do
            if desc:IsA("ProximityPrompt") and desc.Enabled then return false end
        end
        for _,child in ipairs(floor1Door:GetChildren()) do
            if child:IsA("ProximityPrompt") and child.Enabled then return false end
        end
        return true
    end)
    return ok and res or false
end

