--// DESYNC HOOKS
local function send_hook(packet)
    -- Só funciona se estiver roubando E o desync estiver ativo no ciclo
    if not State.stealing or not State.desync then
        return
    end

    if packet.PacketId == 0x1B then
        local b = packet.AsBuffer
        buffer.writeu32(b, 1, 0xFFFFFFFF)
        buffer.writeu32(b, 5, 0xFFFFFFFF)
        buffer.writeu32(b, 9, 0xFFFFFFFF)
        packet:SetData(b)
    end
end

local function recv_hook(packet)
    -- Só funciona se estiver roubando E o desync estiver ativo no ciclo
    if not State.stealing or not State.desync then
        return
    end

    if packet.PacketId == 0x1B or packet.PacketId == 0x86 then
        packet:Drop()
    end
end

pcall(function()
    if raknet.add_send_hook then
        raknet.add_send_hook(send_hook)
    end
end)

pcall(function()
    if raknet.add_recv_hook then
        raknet.add_recv_hook(recv_hook)
    end
end)

--// CORE LOGIC (Ativação e Ciclo de Sincronização)
task.spawn(function()
    while true do
        local isStealing = lp:GetAttribute("Stealing") == true
        State.stealing = isStealing

        if isStealing then
            -- Ativa o desync no início do roubo
            State.desync = true
            
            -- Ciclo de 8 segundos (conforme sua base)
            task.wait(8)

            -- Se ainda estiver roubando, faz o blink de sincronização
            if lp:GetAttribute("Stealing") == true then
                State.desync = false
                task.wait(0.15)
                -- Reativa apenas se o roubo continuar
                if lp:GetAttribute("Stealing") == true then
                    State.desync = true
                end
            end
        else
            -- Se não estiver roubando, desliga o desync imediatamente
            State.desync = false
            task.wait(0.2)
        end
    end
end)

