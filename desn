-- [[ LÓGICA DE DESYNC ]]
local function desync_send(packet)
    if not desync_active then return end
    if packet.PacketId == 0x1B then
        local b = packet.AsBuffer
        buffer.writeu32(b, 1, 0xFFFFFFFF)
        buffer.writeu32(b, 5, 0xFFFFFFFF)
        buffer.writeu32(b, 9, 0xFFFFFFFF)
        packet:SetData(b)
    end
end

local function desync_recv(packet)
    if not desync_active then return end
    if packet.PacketId == 0x1B or packet.PacketId == 0x86 then
        packet:Drop()
    end
end

pcall(function()
    raknet.add_send_hook(desync_send)
    raknet.add_recv_hook(desync_recv)
end)

-- [[ MOTOR DE GERENCIAMENTO IMORTAL ]]
local function start_protection()
    task.spawn(function()
        while true do
            last_heartbeat = tick() -- Atualiza o batimento cardíaco
            local isStealing = lp:GetAttribute("Stealing")
            
            if isStealing then
                StatusText.Text = "PROTECTION ACTIVE (3S)"
                StatusText.TextColor3 = Color3.fromRGB(0, 170, 255)
                StatusDot.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
                
                desync_active = true
                task.wait(Config.DefaultDelay)
                
                desync_active = false
                task.wait(0.05)
            else
                desync_active = false
                StatusText.Text = "System Online -- Monitoring"
                StatusText.TextColor3 = Color3.fromRGB(180, 180, 190)
                StatusDot.BackgroundColor3 = Color3.fromRGB(0, 255, 150)
                task.wait(0.2)
            end
        end
    end)
end

