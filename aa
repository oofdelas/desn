-- Cor do skeleton
local SKEL_COLOR = Color3.fromRGB(180, 80, 255)
local JOINT_SIZE = 0.18
local BONE_THICKNESS = 0.1

local skeletonFolder = nil
local boneObjects = {} -- { part = cylinder, joint1 = sphere, joint2 = sphere }
local jointObjects = {}

local function clearSkeleton()
    if skeletonFolder then
        skeletonFolder:Destroy()
        skeletonFolder = nil
    end
    boneObjects = {}
    jointObjects = {}
end

local function makeCylinder(parent)
    local p = Instance.new("Part")
    p.Shape = Enum.PartType.Cylinder
    p.Material = Enum.Material.SmoothPlastic
    p.Color = SKEL_COLOR
    p.Anchored = true
    p.CanCollide = false
    p.CanTouch = false
    p.CanQuery = false
    p.CastShadow = false
    p.Transparency = 0.15
    p.Size = Vector3.new(1, BONE_THICKNESS, BONE_THICKNESS)
    p.Parent = parent
    return p
end

local function makeSphere(parent)
    local p = Instance.new("Part")
    p.Shape = Enum.PartType.Ball
    p.Material = Enum.Material.SmoothPlastic
    p.Color = SKEL_COLOR
    p.Anchored = true
    p.CanCollide = false
    p.CanTouch = false
    p.CanQuery = false
    p.CastShadow = false
    p.Transparency = 0.1
    p.Size = Vector3.new(JOINT_SIZE, JOINT_SIZE, JOINT_SIZE)
    p.Parent = parent
    return p
end

local function buildSkeleton()
    clearSkeleton()

    local char = lp.Character
    if not char then return end

    skeletonFolder = Instance.new("Folder")
    skeletonFolder.Name = "AlbuxSkeleton"
    skeletonFolder.Parent = workspace

    -- Criar ossos (cilindros) e juntas (esferas)
    for _, pair in ipairs(BONE_PAIRS) do
        local p1Name, p2Name = pair[1], pair[2]
        local part1 = char:FindFirstChild(p1Name)
        local part2 = char:FindFirstChild(p2Name)

        if part1 and part2 then
            local bone = makeCylinder(skeletonFolder)
            local joint1 = makeSphere(skeletonFolder)
            local joint2 = makeSphere(skeletonFolder)

            table.insert(boneObjects, {
                bone = bone,
                joint1 = joint1,
                joint2 = joint2,
                p1Name = p1Name,
                p2Name = p2Name
            })
        end
    end
end

local function positionBone(bone, from, to)
    local dist = (to - from).Magnitude
    if dist < 0.01 then return end
    bone.Size = Vector3.new(dist, BONE_THICKNESS, BONE_THICKNESS)
    bone.CFrame = CFrame.lookAt(from, to) * CFrame.new(0, 0, -dist / 2) * CFrame.Angles(0, math.pi / 2, 0)
end

local function updateSkeleton()
    if not skeletonFolder then return end

    local char = lp.Character
    if not char or not lastSafeCFrame then return end

    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    for _, entry in ipairs(boneObjects) do
        local part1 = char:FindFirstChild(entry.p1Name)
        local part2 = char:FindFirstChild(entry.p2Name)

        if part1 and part2 then
            -- Calcular posição relativa ao HRP salvo
            local rel1 = hrp.CFrame:ToObjectSpace(part1.CFrame)
            local rel2 = hrp.CFrame:ToObjectSpace(part2.CFrame)

            local world1 = (lastSafeCFrame * rel1).Position
            local world2 = (lastSafeCFrame * rel2).Position

            -- Posicionar osso
            positionBone(entry.bone, world1, world2)

            -- Posicionar juntas
            entry.joint1.CFrame = CFrame.new(world1)
            entry.joint2.CFrame = CFrame.new(world2)

            entry.bone.Transparency = 0.15
            entry.joint1.Transparency = 0.1
            entry.joint2.Transparency = 0.1
        end
    end
end

local function hideSkeleton()
    for _, entry in ipairs(boneObjects) do
        entry.bone.Transparency = 1
        entry.joint1.Transparency = 1
        entry.joint2.Transparency = 1
    end
end

