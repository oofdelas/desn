local function saveUIPosition(position)
    local data = {
        X = position.X.Scale,
        XOffset = position.X.Offset,
        Y = position.Y.Scale,
        YOffset = position.Y.Offset
    }
    writefile(configFile, HttpService:JSONEncode(data))
end

local function loadUIPosition()
    if isfile(configFile) then
        local success, data = pcall(function()
            return HttpService:JSONDecode(readfile(configFile))
        end)
        if success and data then
            return UDim2.new(data.X, data.XOffset, data.Y, data.YOffset)
        end
    end
    return UDim2.new(0.5, -135, 0.1, 0)
end

--// DESYNC HOOKS
local function send_hook(packet)
    if not State.stealing or not State.desync then return end
    if packet.PacketId == 0x1B then
        local b = packet.AsBuffer
        buffer.writeu32(b, 1, 0xFFFFFFFF)
        buffer.writeu32(b, 5, 0xFFFFFFFF)
        buffer.writeu32(b, 9, 0xFFFFFFFF)
        packet:SetData(b)
    end
end

local function recv_hook(packet)
    if not State.stealing or not State.desync then return end
    if packet.PacketId == 0x1B or packet.PacketId == 0x86 then
        packet:Drop()
    end
end

