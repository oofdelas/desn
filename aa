        TweenService:Create(main, TweenInfo.new(0.15), {Size = UDim2.new(0, 267, 0, 156)}):Play()
    end
end)

UIS.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
        TweenService:Create(main, TweenInfo.new(0.15), {Size = UDim2.new(0, 270, 0, 158)}):Play()
        saveUIPosition(main.Position)
    end
end)

--// RENDER LOOP - SKELETON
RunService.RenderStepped:Connect(function()
    if lastSafePos and State.stealing and State.desync then
        local char = lp.Character
        if not char then return end

        if not skeletonFolder or not skeletonFolder.Parent then
            buildSkeleton()
        end

        updateSkeleton()
    else
        if skeletonFolder and skeletonFolder.Parent then
            hideSkeleton()
        end
    end
end)

print("[ALBUX DESYNC V4] 💜 Loaded - Skeleton Mode Active")
